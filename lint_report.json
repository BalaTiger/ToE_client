se, gs.drawReveal.card.id, gs.abilityData.godCard.id, gs.gameOver, gs, playTickSound]","fix":{"range":[290205,290304],"text":"[isMpCthDecisionPhase, gs.phase, gs.drawReveal.card.id, gs.abilityData.godCard.id, gs.gameOver, gs, playTickSound]"}}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has missing dependencies: '_cthContinueRestDraws' and 'gs'. Either include them or remove the dependency array.","line":5543,"column":5,"nodeType":"ArrayExpression","endLine":5543,"endColumn":39,"suggestions":[{"desc":"Update the dependencies array to be: [_cthContinueRestDraws, gs, gs?._mpAutoCthDecision, isBlocked]","fix":{"range":[291457,291491],"text":"[_cthContinueRestDraws, gs, gs?._mpAutoCthDecision, isBlocked]"}}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has missing dependencies: 'applyNextTurnGs' and 'gs'. Either include them or remove the dependency array.","line":5610,"column":5,"nodeType":"ArrayExpression","endLine":5610,"endColumn":31,"suggestions":[{"desc":"Update the dependencies array to be: [applyNextTurnGs, gs, gs?._mpEndTurn, isBlocked]","fix":{"range":[294703,294729],"text":"[applyNextTurnGs, gs, gs?._mpEndTurn, isBlocked]"}}]},{"ruleId":"react-hooks/exhaustive-deps","severity":1,"message":"React Hook useEffect has missing dependencies: 'gs' and 'playTickSound'. Either include them or remove the dependency array.","line":5626,"column":5,"nodeType":"ArrayExpression","endLine":5626,"endColumn":72,"suggestions":[{"desc":"Update the dependencies array to be: [isMultiplayer, gs.phase, gs.currentTurn, gs._turnKey, gs.gameOver, gs, playTickSound]","fix":{"range":[295403,295470],"text":"[isMultiplayer, gs.phase, gs.currentTurn, gs._turnKey, gs.gameOver, gs, playTickSound]"}}]},{"ruleId":"no-unused-vars","severity":2,"message":"'handleDrawConfirm' is defined but never used. Allowed unused vars must match /^[A-Z_]/u.","line":6246,"column":12,"nodeType":"Identifier","messageId":"unusedVar