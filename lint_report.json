desc:'你与相邻角色各失去2HP',type:'adjDamageHP',val:2}},\n  C3:{pos:{name:'圣甲虫',desc:'你回复1HP与1SAN',type:'selfHealBoth',val:1},negS:{name:'惊慌失措',desc:'你失去2SAN，随机弃1张牌（强制触发）',type:'selfDamageDiscardSAN',val:2,forced:true},negA:{name:'瘟疫蔓延',desc:'你与相邻角色失去2HP和1SAN',type:'adjDamageBoth',hpVal:2,sanVal:1}},\n  C4:{pos:{name:'触底反弹',desc:'选择一名角色，与其交换全部手牌',type:'swapAllHands',val:0},negS:{name:'恶毒诅咒',desc:'你失去2HP与2SAN',type:'selfDamageHPSAN',hpVal:2,sanVal:2},negA:{name:'末日预兆',desc:'全体存活角色失去1HP和1SAN',type:'allDamageBoth',val:1}},\n  D1:{pos:{name:'秤心仪式',desc:'你失去3HP，回复1SAN',type:'sacHealSelfSAN',val:1},negS:{name:'致命尖刺',desc:'你失去2HP，若你手牌数≥4则额外失去2HP',type:'selfDamageHPCond',val:2,bonus:2,condType:'handHigh',condVal:4},negA:{name:'钻地魔虫',desc:'全体存活角色失去1HP，然后随机选择一名角色失去1HP',type:'allDamageHPRandomExtra',val:1}},\n  D2:{pos:{name:'穴居人战争',desc:'你与另一名角色各亮一张手牌，数字编号更大的一方收下这两张牌',type:'caveDuel',val:0},negS:{name:'恐怖直视',desc:'你失去1SAN，若你手牌数≤2则额外失去2SAN',type:'selfDamageSANCond',val:1,bonus:2,condType:'handLow',condVal:2},negA:{name:'绝血侵蚀',desc:'你失去3HP，然后选一名角色偷看其一张手牌',type:'selfDamageHPPeek',val:3}},\n  D3:{pos:{name:'药王慈怀',desc:'你失去1SAN，全体回复1HP',type:'sacHealHP',val:1},negS:{name:'遗忘咒语',desc:'你失去2HP与1SAN',type:'selfDamageHPSAN',hpVal:2,sanVal:1},negA:{name:'意志崩散',desc:'你失去3SAN',type:'selfDamageSAN',val:3}},\n  D4:{pos:{name:'狂化',desc:'你失去1SAN，直到回合结束，你造成的伤害+1',type:'selfBerserk',val:1},negS:{name:'扭伤',desc:'你失去1HP，下回合开始时你不能摸牌（强制触发）',type:'selfDamageSkipDraw',val:1,forced:true},negA:{name:'同归深渊',desc:'你失去2HP与2SAN，相邻角色各失去1HP与1SAN',type:'selfDamageAdjDamageBoth',hpVal:2,sanVal:2,adjHpVal:1,adjSanVal:1,forced:true}},\n};\nconst ZONE_VARIANTS=['pos','negS','negA'];\nconst LETTERS=['A','B','C','D'],NUMS=[1,2,3,4];\nconst AI_NAMES=['艾伦','贝拉','卡洛斯','黛安娜'];\nconst ROLE_TREASURE='寻宝者',ROLE_HUNTER='追猎者',ROLE_CULTIST='邪祀者';\nconst GOD_DEFS={\n  NYA:{godKey:'NYA',name:'伏行之混沌',power:'千人千貌',levels:[{handPenalty:2},{handPenalty:1},{handPenalty:0}]},\n  CTH:{godKey:'CTH',name:'拉莱耶之主',power:'梦访拉莱耶',levels:[{extraDraws:1},{extraDraws:2},{extraDraws:3}]},\n};\nconst shuffle=a=>{const b=[...a];for(let i=b.length-1;i>0;i--){const j=0|Math.random()*(i+1);[b[i],b[j]]=[b[j],b[i]];}return b;};\nconst clamp=(v,lo=0,hi=10)=>Math.max(lo,Math.min(hi,v));\nconst copyPlayers=ps=>ps.map(p=>({...p,hand:[...p.hand],godZone:[...(p.godZone||[])]}));\nconst isWinHand=h=>{const ls=new Set(h.map(c=>c.letter)),ns=new Set(h.map(c=>c.number));return LETTERS.every(l=>ls.has(l))&&NUMS.every(n=>ns.has(n));};\n\nfunction mkDeck(){\n  let id=0;\n  const zc=LETTERS.flatMap(L=>NUMS.flatMap(N=>ZONE_VARIANTS.map(v=>({id:id++,key:`${L}${N}`,letter:L,number:N,variant:v,isZone:true,...FIXED_ZONE_EFFECTS[`${L}${N}`][v]}))));\n  const gc=[...Array(4).fill(0).map(()=>({id:id++,isGod:true,godKey:'NYA',key:'NYA',type:'god',...GOD_DEFS.NYA})),...Array(4).fill(0).map(()=>({id:id++,isGod:true,godKey:'CTH',key:'CTH',type:'god',...GOD_DEFS.CTH}))];\n  return shuffle([...zc,...gc]);\n}\n\nfunction mkRoles(N=5) {\n  if(N<2)throw new Error('人数不足');\n  if(N===2)return shuffle(['寻宝者','追猎者','邪祀者']).slice(0,2);\n  const roles=['寻宝者','追猎者','邪祀者'];\n  const counts={'寻宝者':1,'追猎者':1,'邪祀者':1};\n  const limit=Math.floor(N/2);\n  for(let i=3;i<N;i++){\n    const avail=['寻宝者'];\n    if(counts['追猎者']<limit)avail.push('追猎者');\n    if(counts['邪祀者']<limit)avail.push('邪祀者');\n    const pick=avail[0|Math.random()*avail.length];\n    roles.push(pick);counts[pick]++;\n  }\n  return shuffle(roles);\n}\n\nfunction getPrevLivingIndex(players,ci){for(let s=1;s<players.length;s++){const i=(ci-s+players.length)%players.length;if(i!==ci&&!players[i].isDead)return i;}return null;}\nfunction getNextLivingIndex(players,ci){for(let s=1;s<players.length;s++){const i=(ci+s)%players.length;if(i!==ci&&!players[i].isDead)return i;}return null;}\nfunction getAdjacentTargets(p,ci){const v=getPrevLivingIndex(p,ci),n=getNextLivingIndex(p,ci);return[ci,...[v,n].filter((x,i,a)=>x!=null&&a.indexOf(x)===i)];}\n\nfunction aiChooseRevealCard(zoneH,hunterHand){\n  const rc=zoneH.find(c=>hunterHand.some(h=>!h.isGod&&(h.letter===c.letter||h.number===c.number)))||zoneH[0|Math.random()*zoneH.length];\n  return rc;\n}\n\nfunction estimateZoneCardKeepScore(card,ci,players){\n  const self=players[ci];\n  if(!self||self.isDead)return -99;\n  let score=0;\n  const isCultist=self.role===ROLE_CULTIST;\n  const dmgBonus=self.damageBonus||0;\n  \n  if(isCultist){\n    const livingPlayers=players.filter(p=>!p.isDead);\n    const minSan=Math.min(...livingPlayers.map(p=>p.san));\n    \n    const SAN_TO_HP_RATIO=1.8;\n    \n    const checkInstantWin=(targets,hpLoss,sanLoss)=>{\n      for(const idx of targets){\n        const target=players[idx];\n        if(target.isDead)continue;\n        const newHp=target.hp-(hpLoss||0)-dmgBonus;\n        const newSan=target.san-(sanLoss||0);\n        if(newSan<=0&&newHp>0)return true;\n      }\n      return false;\n    };\n    \n    const checkHunterKill=(targets,hpLoss)=>{\n      let bonus=0;\n      for(const idx of targets){\n        const target=players[idx];\n        if(target.role===ROLE_HUNTER&&!target.isDead){\n          const newHp=target.hp-(hpLoss||0)-dmgBonus;\n          if(newHp<=0&&target.san>=4)bonus+=5;\n        }\n      }\n      return bonus;\n    };\n    \n    const calcHPSanScore=(hpDelta,sanDelta,targetIdx,isSelf)=>{\n      const target=players[targetIdx];\n      if(!target||target.isDead)return 0;\n      \n      let hpScore=0,sanScore=0;\n      \n      if(sanDelta<0){\n        const sanUrgency=target.san<=-sanDelta?3:0;\n        sanScore=(-sanDelta)*SAN_TO_HP_RATIO*1.2+sanUrgency;\n      }else if(sanDelta>0){\n        if(isSelf&&self.hp<=3&&minSan>3){\n          sanScore=-sanDelta*SAN_TO_HP_RATIO*0.3;\n        }else{\n          sanScore=-sanDelta*SAN_TO_HP_RATIO*1.2;\n        }\n      }\n      \n      if(hpDelta>0){\n        hpScore=hpDelta*1.0;\n      }else if(hpDelta<0){\n        const deathRisk=target.hp<=-hpDelta+dmgBonus?3:0;\n        hpScore=hpDelta*1.2-deathRisk;\n      }\n      \n      if(isSelf){\n        return hpScore+sanScore;\n      }else{\n        return (hpScore+sanScore)*0.7;\n      }\n    };\n    \n    const getTargetsAndValues=()=>{\n      switch(card.type){\n        case 'selfHealHP':\n          return {targets:[ci],hpDelta:card.val,sanDelta:0,hpLoss:0,sanLoss:0};\n        case 'selfHealSAN':\n          return {targets:[ci],hpDelta:0,sanDelta:card.val,hpLoss:0,sanLoss:0};\n        case 'selfHealBoth':\n          return {targets:[ci],hpDelta:card.val,sanDelta:card.val,hpLoss:0,sanLoss:0};\n        case 'selfHealBoth21':\n          return {targets:[ci],hpDelta:2,sanDelta:1,hpLoss:0,sanLoss:0};\n        case 'selfHealHPSelfDamageSAN':\n          return {targets:[ci],hpDelta:card.hpVal,sanDelta:-card.sanVal,hpLoss:0,sanLoss:card.sanVal};\n        case 'selfRevealHandHP':\n          return {targets:[ci],hpDelta:10,sanDelta:0,hpLoss:0,sanLoss:0};\n        case 'selfRevealHandSAN':\n          return {targets:[ci],hpDelta:0,sanDelta:10,hpLoss:0,sanLoss:0};\n        case 'adjHealHP':\n          return {targets:getAdjacentTargets(players,ci),hpDelta:card.val,sanDelta:0,hpLoss:0,sanLoss:0};\n        case 'sacHealHP':\n          return {targets:[ci,...livingPlayers.map((_,i)=>i)],hpDelta:1,sanDelta:-1,hpLoss:0,sanLoss:1,special:'sacHealHP'};\n        case 'sacHealSelfSAN':\n          return {targets:[ci],hpDelta:-3,sanDelta:card.val,hpLoss:3,sanLoss:0};\n        case 'selfDamageHP':\n        case 'selfDamageDiscardHP':\n          return {targets:[ci],hpDelta:0,sanDelta:0,hpLoss:card.val,sanLoss:0};\n        case 'selfDamageSAN':\n        case 'selfDamageDiscardSAN':\n          return {targets:[ci],hpDelta:0,sanDelta:0,hpLoss:0,sanLoss:card.val};\n        case 'selfDamageHPSAN':\n          return {targets:[ci],hpDelta:0,sanDelta:0,hpLoss:card.hpVal,sanLoss:card.sanVal};\n        case 'selfDamageRestHP':\n          return {targets:[ci],hpDelta:0,sanDelta:0,hpLoss:card.val,sanLoss:0};\n        case 'selfDamageRestSAN':\n          return {targets:[ci],hpDelta:0,sanDelta:0,hpLoss:0,sanLoss:card.val};\n        case 'selfDamageHPPeek':\n          return {targets:[ci],hpDelta:0,sanDelta:0,hpLoss:card.val,sanLoss:0};\n        case 'adjDamageHP':\n          return {targets:getAdjacentTargets(players,ci),hpDelta:0,sanDelta:0,hpLoss:card.val,sanLoss:0};\n        case 'adjDamageSAN':\n          return {targets:getAdjacentTargets(players,ci),hpDelta:0,sanDelta:0,hpLoss:0,sanLoss:card.val};\n        case 'adjDamageBoth':\n          return {targets:getAdjacentTargets(players,ci),hpDelta:0,sanDelta:0,hpLoss:card.hpVal,sanLoss:card.sanVal};\n        case 'allDamageHP':\n          return {targets:livingPlayers.map((_,i)=>i),hpDelta:0,sanDelta:0,hpLoss:card.val,sanLoss:0};\n        case 'allDamageSAN':\n          return {targets:livingPlayers.map((_,i)=>i),hpDelta:0,sanDelta:0,hpLoss:0,sanLoss:card.val};\n        case 'allDamageBoth':\n          return {targets:livingPlayers.map((_,i)=>i),hpDelta:0,sanDelta:0,hpLoss:card.val,sanLoss:card.val};\n        case 'selfDamageAdjDamageBoth':\n          return {targets:[ci,...getAdjacentTargets(players,ci)],hpDelta:0,sanDelta:0,hpLoss:card.hpVal,sanLoss:card.sanVal,special:'selfDamageAdjDamageBoth',adjHpLoss:card.adjHpVal,adjSanLoss:card.adjSanVal};\n        default:\n          return null;\n      }\n    };\n    \n    const cardInfo=getTargetsAndValues();\n    \n    if(cardInfo){\n      const{targets,hpDelta,sanDelta,hpLoss,sanLoss,special,adjHpLoss,adjSanLoss}=cardInfo;\n      \n      if(special==='selfDamageAdjDamageBoth'){\n        if(checkInstantWin([ci],hpLoss,sanLoss))return 100;\n        const adjTargets=targets.filter(idx=>idx!==ci);\n        if(checkInstantWin(adjTargets,adjHpLoss,adjSanLoss))return 100;\n      }else if(checkInstantWin(targets,hpLoss,sanLoss)){\n        return 100;\n      }\n      \n      let hunterBonus=0;\n      if(special==='selfDamageAdjDamageBoth'){\n        hunterBonus=checkHunterKill([ci],hpLoss)+checkHunterKill(targets.filter(idx=>idx!==ci),adjHpLoss);\n      }else{\n        hunterBonus=checkHunterKill(targets,hpLoss);\n      }\n      \n      let totalScore=hunterBonus;\n      \n      if(special==='sacHealHP'){\n        totalScore+=calcHPSanScore(0,-1,ci,true);\n        targets.filter(idx=>idx!==ci).forEach(idx=>{\n          totalScore+=calcHPSanScore(1,0,idx,false);\n        });\n      }else if(special==='selfDamageAdjDamageBoth'){\n        totalScore+=calcHPSanScore(-hpLoss,-sanLoss,ci,true);\n        targets.filter(idx=>idx!==ci).forEach(idx=>{\n          totalScore+=calcHPSanScore(-adjHpLoss,-adjSanLoss,idx,false);\n        });\n      }else if(hpLoss||sanLoss){\n        targets.forEach(idx=>{\n          const isSelf=idx===ci;\n          totalScore+=calcHPSanScore(-hpLoss,-sanLoss,idx,isSelf);\n        });\n      }else if(hpDelta||sanDelta){\n        targets.forEach(idx=>{\n          const isSelf=idx===ci;\n          totalScore+=calcHPSanScore(hpDelta,sanDelta,idx,isSelf);\n        });\n      }\n      \n      score=totalScore;\n    }else{\n      switch(card.type){\n        case 'selfRenounceGod':\n          score=-(self.godName?1:0.5);\n          break;\n        case 'selfBerserk':\n          score=2+minSan*0.2;\n          break;\n        case 'damageLink':\n          score=0.5;\n          break;\n        case 'swapAllHands':\n          score=0.3;\n          break;\n        case 'caveDuel':\n          score=self.hand.length>0?0.3:-0.3;\n          break;\n        case 'globalOnlySwap':\n          score=0.2;\n          break;\n        case 'allDiscard':\n          score=-0.3;\n          break;\n        case 'adjRest':\n          score=0;\n          break;\n        default:\n          score=0;\n      }\n    }\n    \n    return score;\n  }\n  \n  switch(card.type){\n    case 'selfHealHP': score=(10-self.hp)*1.5; break;\n    case 'selfHealSAN': score=(10-self.san)*1.4; break;\n    case 'selfHealBoth': score=(10-self.hp)+(10-self.san); break;\n    case 'selfHealBoth21': score=(10-self.hp)*1.5+(10-self.san)*0.8; break;\n    case 'sacHealSelfSAN': score=(10-self.san)*1.8-1.2; break;\n    case 'selfRevealHandHP': score=(10-self.hp)*2.2+1.5; break;\n    case 'selfRevealHandSAN': score=(10-self.san)*2.2+1.5; break;\n    case 'adjHealHP':\n      score=getAdjacentTargets(players,ci).reduce((sum,idx)=>sum+(10-players[idx].hp)*0.6,0);\n      break;\n    case 'globalOnlySwap':\n      score=self.role===ROLE_TREASURE?3.5:0.8;\n      break;\n    case 'selfBerserk':\n      score=self.role===ROLE_HUNTER?7.2:-1.5;\n      break;\n    case 'swapAllHands':{\n      const bestOther=players.reduce((best,p,i)=>{\n        if(i===ci||p.isDead)return best;\n        return p.hand.length>best.count?{idx:i,count:p.hand.length}:best;\n      },{idx:-1,count:-1});\n      const cardDiff=(bestOther.count-self.hand.length);\n      if(self.role===ROLE_HUNTER){\n        score=cardDiff>0?cardDiff*3+2.5:(self.hand.length>(self._nyaHandLimit??4)?-2:-0.8);\n      }else if(self.role===ROLE_TREASURE) score=cardDiff>1?cardDiff*1.5:0.5;\n      else score=0.5;\n      break;\n    }\n    case 'caveDuel':\n      score=self.hand.length>0?1.2:-0.8;\n      break;\n    case 'selfDamageHPPeek':\n      score=-card.val*1.8+0.5;\n      break;\n    case 'damageLink':\n      score=self.role===ROLE_HUNTER?4.2:-1.0;\n      break;\n    case 'selfDamageHP':\n    case 'selfDamageSAN':\n      score=-card.val*2.1;\n      break;\n    case 'selfDamageDiscardHP':\n    case 'selfDamageDiscardSAN':\n      score=-card.val*2.2-Math.min(self.hand.length,1)*1.2;\n      break;\n    case 'selfDamageHPSAN':\n      score=-(card.hpVal||0)*1.8-(card.sanVal||0)*2.1;\n      break;\n    case 'selfDamageAdjDamageBoth':\n      score=-(card.hpVal||0)*1.8-(card.sanVal||0)*2.1-((card.adjHpVal||0)*1.8+(card.adjSanVal||0)*2.1)*0.5;\n      break;\n    case 'selfDamageRestHP':\n    case 'selfDamageRestSAN':\n      score=-3.1;\n      break;\n    case 'selfRenounceGod':\n      score=-(self.godName?2.8:1.4);\n      break;\n    default:\n      if(card.type.startsWith('allDamage')||card.type.startsWith('adjDamage')||card.type==='allDiscard'){\n        const isWideHpDamage=card.type==='allDamageHP'||card.type==='adjDamageHP'||card.type==='allDamageBoth'||card.type==='adjDamageBoth';\n        if(self.role===ROLE_HUNTER) score=isWideHpDamage?4.2:2.6;\n        else score=-1.6;\n      }else if(card.type.startsWith('sac')){\n        score=self.role===ROLE_TREASURE?0.6:1.6;\n      }\n      break;\n  }\n  if(self.hp<=2&&(card.type.includes('DamageHP')||(card.type==='selfDamageHPSAN'&&(card.hpVal||0)>0)))score-=4;\n  if(self.san<=2&&(card.type.includes('DamageSAN')||(card.type==='selfDamageHPSAN'&&(card.sanVal||0)>0)))score-=4;\n  return score;\n}\n\nfunction aiShouldKeepZoneCard(card,ci,players,forced=false){\n  if(forced)return true;\n  const score=estimateZoneCardKeepScore(card,ci,players);\n  if(card.variant==='pos')return score>-1.5;\n  return score>1.1;\n}\n\nfunction applyFx(card,ci,ti,ps,deck,disc,avoidNegative=false,avoidNegativeFor=[]){\n  let P=copyPlayers(ps),D=[...deck],Disc=[...disc],msgs=[];\n  let statePatch={};\n  const dmgBonus=P[ci]?.damageBonus||0;\n  const healHP=(i,v)=>{if(i==null||!P[i]||P[i].isDead)return;P[i].hp=clamp(P[i].hp+v);};\n  const healSAN=(i,v)=>{if(i==null||!P[i]||P[i].isDead)return;P[i].san=clamp(P[i].san+v);};\n  const killPlayer=i=>{\n    if(i==null||!P[i]||P[i].isDead)return;\n    P[i].isDead=true;P[i].roleRevealed=true;\n    Disc.push(...P[i].hand);P[i].hand=[];\n    if(P[i].godZone?.length){Disc.push(...P[i].godZone);P[i].godZone=[];P[i].godName=null;P[i].godLevel=0;}\n  };\n  const hurtHP=(i,v)=>{\n    if(i==null||!P[i]||P[i].isDead||(avoidNegative&&i===ci)||avoidNegativeFor.includes(i))return;\n    const actualDamage=v;\n    P[i].hp=clamp(P[i].hp-actualDamage);\n    if(P[i].damageLink&&P[i].damageLink.active&&actualDamage>0){\n      const partnerIdx=P[i].damageLink.partner;\n      if(P[partnerIdx]&&!P[partnerIdx].isDead){\n        P[i].damageLink.active=false;\n        P[partnerIdx].damageLink.active=false;\n        P[partnerIdx].hp=clamp(P[partnerIdx].hp-actualDamage);\n        if(P[partnerIdx].hp<=0)killPlayer(partnerIdx);\n      }\n    }\n    if(P[i].hp<=0)killPlayer(i);\n  };\n  const hurtSAN=(i,v)=>{if(i==null||!P[i]||P[i].isDead||(avoidNegative&&i===ci)||avoidNegativeFor.includes(i))return;P[i].san=clamp(P[i].san-v);};\n  const dealHP=(i,v)=>hurtHP(i,v+dmgBonus);\n  const dealSAN=(i,v)=>hurtSAN(i,v+dmgBonus);\n  const randDiscard=(i,count=1)=>{if(i==null||!P[i]||(avoidNegative&&i===ci)||avoidNegativeFor.includes(i))return;for(let n=0;n<count;n++){if(P[i].hand.length){const x=0|Math.random()*P[i].hand.length;const c=P[i].hand.splice(x,1)[0];Disc.push(c);}}}; \n  const toggleRest=i=>{if(i==null||!P[i]||P[i].isDead||(avoidNegative&&i===ci)||avoidNegativeFor.includes(i))return;P[i].isResting=!P[i].isResting;};\n  const adjacent=getAdjacentTargets(P,ci);\n  const others=P.map((_,i)=>i).filter(i=>i!==ci&&!P[i].isDead);\n  const allLiving=P.map((_,i)=>i).filter(i=>!P[i].isDead);\n  const actor=P[ci];\n  \n  const checkCondition=(condType,condVal,actor)=>{\n    switch(condType){\n      case 'handHigh': return actor.hand.length>=condVal;\n      case 'handLow': return actor.hand.length<=condVal;\n      case 'hpLow': return actor.hp<=condVal;\n      case 'sanHigh': return actor.san>=condVal;\n      default: return false;\n    }\n  };\n  \n  const applyConditionalDamage=(type,card)=>{\n    if(!avoidNegative&&!avoidNegativeFor.includes(ci)){\n      let totalDamage=card.val||0;\n      let bonusDamage=0;\n      const conditionMet=checkCondition(card.condType,card.condVal,actor);\n      if(conditionMet){\n        bonusDamage=card.bonus||0;\n        totalDamage+=bonusDamage;\n      }\n      if(type==='hp'){\n        hurtHP(ci,totalDamage);\n      }else if(type==='san'){\n        hurtSAN(ci,totalDamage);\n      }\n    }\n  };\n  \n  const applyAOEDamage=(targets,damageType,value,hpVal,sanVal)=>{\n    targets.forEach(i=>{\n      if(!avoidNegativeFor.includes(i)){\n        if(damageType==='both'||damageType.includes('hp'))dealHP(i,hpVal||value);\n        if(damageType==='both'||damageType.includes('san'))dealSAN(i,sanVal||value);\n      }\n    });\n  };\n  \n  const applyGlobalAOEDamage=(damageType,value)=>{\n    allLiving.forEach(i=>{\n      if(!avoidNegativeFor.includes(i)){\n        if(damageType==='both'||damageType.includes('hp'))dealHP(i,value);\n        if(damageType==='both'||damageType.includes('san'))dealSAN(i,value);\n      }\n    });\n  };\n  switch(card.type){\n    case 'selfHealHP': healHP(ci,card.val);break;\n    case 'selfHealSAN': healSAN(ci,card.val);break;\n    case 'selfHealBoth': healHP(ci,1);healSAN(ci,1);break;\n    case 'selfHealBoth21': healHP(ci,2);healSAN(ci,1);break;\n    case 'selfHealAdjDamageHP': healHP(ci,card.val);adjacent.filter(i=>i!==ci).forEach(i=>dealHP(i,card.val));break;\n    case 'adjHealHP': adjacent.forEach(i=>healHP(i,card.val));break;\n    case 'selfRevealHandHP': actor.hp=10;actor.revealHand=true;break;\n    case 'selfRevealHandSAN': actor.san=Math.min(10,actor.san+card.val);actor.revealHand=true;break;\n    case 'globalOnlySwap': statePatch={globalOnlySwapOwner:ci};break;\n    case 'selfDamageHP': hurtHP(ci,card.val);break;\n    case 'selfDamageSAN': hurtSAN(ci,card.val);break;\n    case 'selfDamageHPCond': applyConditionalDamage('hp',card);break;\n    case 'selfDamageSANCond': applyConditionalDamage('san',card);break;\n    case 'selfDamageHPSAN': hurtHP(ci,card.hpVal||0);hurtSAN(ci,card.sanVal||0);break;\n    case 'selfDamageAdjDamageBoth':\n      hurtHP(ci,card.hpVal||0);hurtSAN(ci,card.sanVal||0);\n      adjacent.filter(i=>i!==ci).forEach(i=>{dealHP(i,card.adjHpVal||0);dealSAN(i,card.adjSanVal||0);});\n      break;\n    case 'selfDamageDiscardHP': hurtHP(ci,card.val);randDiscard(ci,1);break;\n    case 'selfDamageDiscardSAN': hurtSAN(ci,card.val);randDiscard(ci,1);break;\n    case 'selfDamageRestHP': hurtHP(ci,card.val);toggleRest(ci);break;\n    case 'selfDamageRestSAN': hurtSAN(ci,card.val);toggleRest(ci);break;\n    case 'selfDamageSkipDraw': hurtHP(ci,card.val);P[ci].skipNextDraw=true;break;\n    case 'selfDamageHPPeek': hurtHP(ci,card.val);break;\n    case 'adjDamageHP': applyAOEDamage(adjacent,'hp',card.val);break;\n    case 'adjDamageSAN': applyAOEDamage(adjacent,'san',card.val);break;\n    case 'adjDamageBoth': applyAOEDamage(adjacent,'both',card.val,card.hpVal,card.sanVal);break;\n    case 'allDamageHP': applyGlobalAOEDamage('hp',card.val);break;\n    case 'allDamageSAN': applyGlobalAOEDamage('san',card.val);break;\n    case 'allDamageBoth': applyGlobalAOEDamage('both',card.val);break;\n    case 'allDamageHPRandomExtra':\n      applyGlobalAOEDamage('hp',card.val);\n      if(others.length>0){\n        const randomTarget=others[0|Math.random()*others.length];\n        dealHP(randomTarget,1);\n      }\n      break;\n    case 'adjRest': adjacent.forEach(i=>toggleRest(i));break;\n    case 'allDiscard': allLiving.forEach(i=>randDiscard(i,1));break;\n    case 'selfRenounceGod':\n      if(actor.godName){if(actor.godZone?.length)Disc.push(...actor.godZone);actor.godZone=[];actor.godName=null;actor.godLevel=0;}\n      break;\n    case 'sacHealHP': hurtSAN(ci,1);allLiving.forEach(i=>healHP(i,card.val));break;\n    case 'sacHealSelfSAN': hurtHP(ci,3);healSAN(ci,card.val);break;\n    case 'swapAllHands':{\n      const st=ti!=null?ti:others.reduce((b,i)=>P[i].hand.length>P[b].hand.length?i:b,others[0]??ci);\n      if(st!=null&&st!==ci&&P[st]&&!P[st].isDead){const mh=[...P[ci].hand];P[ci].hand=[...P[st].hand];P[st].hand=mh;}\n      break;}\n    case 'selfBerserk': hurtSAN(ci,1);P[ci].damageBonus=(P[ci].damageBonus||0)+1;break;\n    case 'caveDuel': break;\n    case 'damageLink':\n      const validLinkTargets=others.filter(i=>!P[i].damageLink||!P[i].damageLink.active);\n      if(validLinkTargets.length>0){\n        const linkTarget=validLinkTargets[0|Math.random()*validLinkTargets.length];\n        P[ci].damageLink={partner:linkTarget,active:true,expiryOwner:ci};\n        P[linkTarget].damageLink={partner:ci,active:true,expiryOwner:ci};\n      }\n      break;\n  }\n  return{P,D,Disc,msgs,statePatch};\n}\n\nfunction checkWin(players){\n  const hasHunters=players.some(p=>p.role===ROLE_HUNTER);\n  const hasCultists=players.some(p=>p.role===ROLE_CULTIST);\n  for(const p of players)if(!p.isDead&&p.san<=0&&p.hp>0){\n    if(hasCultists){\n      return{winner:'邪祀者'};\n    }else{\n      return{winner:'LOSE_ALL'};\n    }\n  }\n  const nonHunters=players.filter(p=>p.role!==ROLE_HUNTER);\n  if(nonHunters.length&&nonHunters.every(p=>p.isDead)){\n    if(hasHunters){\n      return{winner:'追猎者'};\n    }else{\n      return{winner:'LOSE_ALL'};\n    }\n  }\n  const alivePlayers=players.filter(p=>!p.isDead);\n  if(alivePlayers.length===1){\n    const survivor=alivePlayers[0];\n    if(survivor.role===ROLE_TREASURE){\n      return{winner:'寻宝者'};\n    }else if(survivor.role===ROLE_CULTIST){\n      return{winner:'邪祀者'};\n    }\n  }\n  return null;\n}\n\nfunction resolveGodForAI(ci,godCard,P,Disc,fc){\n  const gk=godCard.godKey;P=P.map(p=>({...p,godZone:[...(p.godZone||[])]}));\n  if(fc&&P[ci].godName&&P[ci].godName!==gk){P[ci].san=clamp(P[ci].san-1);Disc.push(...P[ci].godZone);P[ci].godZone=[];P[ci].godName=null;P[ci].godLevel=0;}\n  let action;\n  if(P[ci].godName===gk&&P[ci].godLevel<3)action='upgrade';\n  else if(P[ci].godName===gk)action='discard';\n  else if(!P[ci].godName)action=fc?'worship':(P[ci]._nyaBorrow||P[ci].role)===ROLE_CULTIST&&Math.random()<0.6?'hand':P[ci].san>4?'worship':'discard';\n  else action='discard';\n  const ev=i=>{P.forEach((p,j)=>{if(j!==i&&p.godName===gk){p.san=clamp(p.san-1);Disc.push(...p.godZone);p.godZone=[];p.godName=null;p.godLevel=0;}});};\n  if(action==='upgrade'){P[ci].godLevel++;P[ci].godZone.push({...godCard});ev(ci);}\n  else if(action==='worship'){P[ci].godName=gk;P[ci].godLevel=1;P[ci].godZone=[{...godCard}];ev(ci);}\n  else if(action==='hand')P[ci].hand.push({...godCard});\n  else Disc.push({...godCard});\n  return{P,Disc};\n}\nfunction aiHandleGod(ci,godCard,P,D,Disc){\n  P[ci].godEncounters=(P[ci].godEncounters||0)+1;\n  P[ci].san=clamp(P[ci].san-P[ci].godEncounters);\n  const r=resolveGodForAI(ci,godCard,P,Disc,!!(P[ci].godName&&P[ci].godName!==godCard.godKey));\n  return{P:r.P,D,Disc:r.Disc};\n}\n\nfunction aiDrawAndApply(ci,ps,deck,disc){\n  let P=copyPlayers(ps),D=[...deck],Disc=[...disc];\n  if(!D.length&&Disc.length){D=shuffle(Disc);Disc=[];}\n  if(!D.length)return{P,D,Disc,drawnCard:null};\n  if(P[ci].skipNextDraw){\n    delete P[ci].skipNextDraw;\n    return{P,D,Disc,drawnCard:null};\n  }\n  const card=D.shift();\n  if(card.isGod){const gr=aiHandleGod(ci,card,P,D,Disc);return{P:gr.P,D:gr.D,Disc:gr.Disc,drawnCard:card};}\n  const isNeg=card.variant==='negS'||card.variant==='negA';\n  if((P[ci]._nyaBorrow||P[ci].role)===ROLE_TREASURE&&isNeg&&!card.forced){\n    const d1=1+(Math.random()*6|0);\n    const dodgeSuccess=d1>=4;\n    if(dodgeSuccess){\n      P[ci].roleRevealed=true;\n      const res=applyFx(card,ci,null,P,D,Disc,true);\n      P=res.P;D=res.D;Disc=res.Disc;P[ci].hand.push(card);\n      return{P,D,Disc,drawnCard:card,statePatch:res.statePatch};\n    }\n  }\n  const keep=aiShouldKeepZoneCard(card,ci,P,false);\n  if(!keep){Disc.push(card);return{P,D,Disc,drawnCard:card};}\n  const res=applyFx(card,ci,null,P,D,Disc);\n  P=res.P;D=res.D;Disc=res.Disc;P[ci].hand.push(card);\n  return{P,D,Disc,drawnCard:card,statePatch:res.statePatch};\n}\n\nfunction startNextTurn(gs,skipTurnIncrement=false){\n  const N=gs.players.length;let P=copyPlayers(gs.players),D=[...gs.deck],Disc=[...gs.discard];\n  let next=gs.currentTurn;for(let i=1;i<=N;i++){next=(gs.currentTurn+i)%N;if(!P[next].isDead)break;}\n  const newTurn=skipTurnIncrement?(gs.turn||0):((gs.turn||0)+1);\n  if(P[gs.currentTurn]?.damageBonus)delete P[gs.currentTurn].damageBonus;\n  if(P[gs.currentTurn]?._nyaBorrow)delete P[gs.currentTurn]._nyaBorrow;\n  if(P[gs.currentTurn]?._nyaHandLimit)delete P[gs.currentTurn]._nyaHandLimit;\n  P.forEach((p,i)=>{\n    const shouldExpire = p.damageLink && (\n      p.damageLink.expiryOwner===next ||\n      (p.damageLink.expiryOwner!=null && (!P[p.damageLink.expiryOwner] || P[p.damageLink.expiryOwner].isDead)) ||\n      (p.damageLink.expiryOwner==null && p.damageLink.expiryTurn<=newTurn)\n    );\n    if(shouldExpire){\n      delete p.damageLink;\n    }\n  });\n  let gso=gs.globalOnlySwapOwner;if(gso===next)gso=null;\n  if(P[next].isResting){\n    P[next].isResting=false;\n    if(P[next].godName==='CTH'&&P[next].godLevel>=1){\n      const ex=GOD_DEFS.CTH.levels[P[next].godLevel-1].extraDraws;\n      for(let d=0;d<ex;d++){const r=aiDrawAndApply(next,P,D,Disc);P=r.P;D=r.D;Disc=r.Disc;const w=checkWin(P);if(w)return{...gs,players:P,deck:D,discard:Disc,gameOver:w};}\n    }\n    return startNextTurn({...gs,players:P,deck:D,discard:Disc,currentTurn:next,huntAbandoned:[],skillUsed:false,restUsed:false,globalOnlySwapOwner:gso,turn:newTurn},true);\n  }\n  const r=aiDrawAndApply(next,P,D,Disc);P=r.P;D=r.D;Disc=r.Disc;\n  const w=checkWin(P);if(w)return{...gs,players:P,deck:D,discard:Disc,gameOver:w,...(r.statePatch||{}),globalOnlySwapOwner:(r.statePatch?.globalOnlySwapOwner??gso),turn:newTurn};\n  if(!P[next].isDead&&(P[next]._nyaBorrow||P[next].role)===ROLE_TREASURE&&isWinHand(P[next].hand))return{...gs,players:P,deck:D,discard:Disc,gameOver:{winner:'寻宝者'},globalOnlySwapOwner:gso,turn:newTurn};\n  return{...gs,players:P,deck:D,discard:Disc,currentTurn:next,phase:'AI_TURN',huntAbandoned:[],_turnKey:(gs._turnKey||0)+1,...(r.statePatch||{}),globalOnlySwapOwner:(r.statePatch?.globalOnlySwapOwner??gso),turn:newTurn};\n}\n\nfunction aiStep(gs){\n  const{players:ps,currentTurn:ct}=gs;let P=copyPlayers(ps),D=[...gs.deck],Disc=[...gs.discard];\n  const ai=P[ct];let alive=P.filter((p,i)=>!p.isDead&&i!==ct);\n  if((ai._nyaBorrow||ai.role)==='寻宝者'&&isWinHand(ai.hand))return{...gs,players:P,gameOver:{winner:'寻宝者'}};\n  if(!gs.skillUsed&&!gs.restUsed){\n    const hi=P[ct].hand.findIndex(c=>c.isGod);\n    if(hi>=0){\n      const hgc=P[ct].hand[hi];const ah=P[ct].godName&&P[ct].godName!==hgc.godKey;\n      if((P[ct]._nyaBorrow||P[ct].role)===ROLE_CULTIST?Math.random()<0.65:Math.random()<0.45){\n        P[ct].hand.splice(hi,1);\n        if(ah){P[ct].san=clamp(P[ct].san-1);Disc.push(...P[ct].godZone);P[ct].godZone=[];P[ct].godName=null;P[ct].godLevel=0;}\n        if(P[ct].godName===hgc.godKey&&P[ct].godLevel<3){P[ct].godLevel++;P[ct].godZone.push({...hgc});}\n        else if(!P[ct].godName||ah){P[ct].godName=hgc.godKey;P[ct].godLevel=1;P[ct].godZone=[{...hgc}];}\n        P.forEach((p,i)=>{if(i!==ct&&p.godName===hgc.godKey){p.san=clamp(p.san-1);Disc.push(...p.godZone);p.godZone=[];p.godName=null;p.godLevel=0;}});\n        const ww=checkWin(P);if(ww)return{...gs,players:P,deck:D,discard:Disc,gameOver:ww};\n      }\n    }\n  }\n  const aiEffRole=gs.globalOnlySwapOwner!=null?'寻宝者':(ai._nyaBorrow||ai.role);\n  const shouldRest=(()=>{\n    if(gs.restUsed||gs.skillUsed)return false;\n    if(ai.hp>=9)return false;\n    if(aiEffRole==='寻宝者')return ai.hp<=7&&Math.random()<0.70;\n    if(aiEffRole==='追猎者'){\n      if(ai.hp<=5)return Math.random()<0.75;\n      return false;\n    }\n    return ai.hp<=4&&Math.random()<0.65;\n  })();\n  if(shouldRest){\n    const d1=(1+Math.random()*6|0),d2=(1+Math.random()*6|0),heal=Math.max(d1,d2);\n    P[ct].hp=clamp(P[ct].hp+heal);P[ct].isResting=true;\n    const win=checkWin(P);if(win)return{...gs,players:P,deck:D,discard:Disc,gameOver:win};\n    const aiHandLimit=P[ct]._nyaHandLimit??4;\n    while(P[ct].hand.length>aiHandLimit){P[ct].hand.shift();}\n    return startNextTurn({...gs,players:P,deck:D,discard:Disc,currentTurn:ct,restUsed:true,skillUsed:false});\n  }\n  const myNonGod=P[ct].hand.filter(c=>!c.isGod);\n  const myProgress=aiEffRole==='寻宝者'\n    ?(new Set(myNonGod.map(c=>c.letter)).size+new Set(myNonGod.map(c=>c.number)).size):0;\n  \n  let skillRate = 0.35;\n  if (aiEffRole === ROLE_HUNTER) skillRate = 0.97;\n  else if (aiEffRole === ROLE_CULTIST) skillRate = 0.65;\n  else if (myProgress >= 7) skillRate = 0.55;\n\n  const canUseSkill = !gs.restUsed && (aiEffRole === ROLE_HUNTER ? true : !gs.skillUsed);\n  const hunterZoneCards = P[ct].hand.filter(c=>!c.isGod);\n  const hunterHandLimit = P[ct]._nyaHandLimit ?? 4;\n  const hunterOverLimit = hunterZoneCards.length > hunterHandLimit;\n  const someoneWounded = P.some((p,i)=>i!==ct && !p.isDead && p.hp < 10);\n  let huntContinue = true;\n  let newAbandoned = gs.huntAbandoned || [];\n  const getHunterTargets = () => P\n    .map((p,i)=>({player:p,idx:i}))\n    .filter(({player,idx})=>!player.isDead && idx!==ct && player.role!==ROLE_HUNTER && !newAbandoned.includes(idx))\n    .filter(({player})=>player.hand.some(c=>!c.isGod));\n  const shouldHunterUseSkill = canUseSkill && aiEffRole===ROLE_HUNTER && hunterZoneCards.length>0 && getHunterTargets().length>0 && (hunterOverLimit || someoneWounded);\n  const useSkill = aiEffRole===ROLE_HUNTER\n    ? shouldHunterUseSkill\n    : (canUseSkill && Math.random() < skillRate && alive.length > 0);\n\n  if(!useSkill){\n    huntContinue = false;\n  }\n\n  if(useSkill){\n    P[ct].roleRevealed=true;\n    let tgt;\n    if(aiEffRole===ROLE_HUNTER){\n      if(hunterZoneCards.length === 0) huntContinue = false;\n      while (huntContinue && P[ct].hand.some(c=>!c.isGod)) {\n        const validTargets = getHunterTargets();\n        if (validTargets.length > 0) {\n          const sortedTargets = [...validTargets].sort((a, b) => {\n            if (!!a.player.roleRevealed !== !!b.player.roleRevealed) return a.player.roleRevealed ? -1 : 1;\n            return a.player.hp - b.player.hp;\n          });\n\n          let foundTarget = false;\n          for (const { player: tgtPlayer, idx: ti } of sortedTargets) {\n            const zoneH = P[ti].hand.filter(c => !c.isGod);\n            if (!zoneH.length) continue;\n            const rc = aiChooseRevealCard(zoneH, P[ct].hand);\n            const mi = P[ct].hand.findIndex(c => c.letter === rc.letter || c.number === rc.number);\n            if (mi >= 0) {\n              const dc = P[ct].hand.splice(mi, 1)[0]; Disc.push(dc);\n              const huntDamage=2+(P[ct].damageBonus||0);\n              P[ti].hp = clamp(P[ti].hp - huntDamage);\n              if (P[ti].hp <= 0) {\n                P[ti].isDead = true; P[ti].roleRevealed = true;\n                if (P[ti].hand.length) {\n                  const randomIndex = Math.floor(Math.random() * P[ti].hand.length);\n                  const stolenCard = P[ti].hand.splice(randomIndex, 1)[0];\n                  P[ct].hand.push(stolenCard);\n                  Disc.push(...P[ti].hand);\n                  P[ti].hand = [];\n                }\n                if (P[ti].godZone?.length) { Disc.push(...P[ti].godZone); P[ti].godZone = []; P[ti].godName = null; P[ti].godLevel = 0; }\n                alive = P.filter((p, i) => !p.isDead && i !== ct);\n                newAbandoned = [];\n                foundTarget = true;\n                break;\n              } else {\n                foundTarget = true;\n                newAbandoned = newAbandoned.filter(i => i !== ti);\n                break;\n              }\n            } else {\n              newAbandoned = [...newAbandoned, ti];\n            }\n            continue;\n          }\n          \n          if (!foundTarget) {\n            huntContinue = false;\n          }\n        } else {\n          huntContinue = false;\n        }\n        \n        const win=checkWin(P);if(win)return{...gs,players:P,deck:D,discard:Disc,gameOver:win};\n      }\n    } else if(aiEffRole===ROLE_CULTIST){\n      const sanScore=p=>(p.hp-p.san);\n      tgt=alive.reduce((b,p)=>sanScore(p)>sanScore(b)?p:b,alive[0]);\n      const ti=P.indexOf(tgt);\n      if(P[ct].hand.length){\n        const hunterThreatTgt=P[ti]?.role===ROLE_HUNTER;\n        const forcedConvertGod=P[ct].hand.find(c=>c.isGod&&P[ti].godName&&P[ti].godName!==c.godKey);\n        const anyGod=P[ct].hand.find(c=>c.isGod);\n        const sanPrefer=hunterThreatTgt\n          ?['allDamageHP','adjDamageHP','allDamageSAN','adjDamageSAN','allDamageBoth','adjDamageBoth','selfDamageSAN']\n          :['allDamageSAN','adjDamageSAN','allDamageBoth','adjDamageBoth','selfDamageSAN'];\n        const sanCard=P[ct].hand.find(c=>sanPrefer.includes(c.type));\n        const sc=forcedConvertGod||anyGod||sanCard||P[ct].hand[0];\n        P[ct].hand=P[ct].hand.filter(c=>c.id!==sc.id);\n        if(sc.isGod){\n          const gr=aiHandleGod(ti,sc,P,D,Disc);P=gr.P;D=gr.D;Disc=gr.Disc;\n        }else{\n          const r=applyFx(sc,ti,ti,P,D,Disc);P=r.P;D=r.D;Disc=r.Disc;P[ti].hand.push(sc);\n        }\n      }\n    } else {\n      const withH=alive.filter(p=>p.hand.length>0);\n      const pool=withH.length?withH:alive;\n      if(myProgress>=7){\n        tgt=pool[0|Math.random()*pool.length];\n      }else{\n        const myL=new Set(myNonGod.map(c=>c.letter));\n        const myN=new Set(myNonGod.map(c=>c.number));\n        const scoreH=h=>h.filter(c=>!c.isGod&&(!myL.has(c.letter)||!myN.has(c.number))).length;\n        tgt=pool.reduce((b,p)=>scoreH(p.hand)>scoreH(b.hand)?p:b,pool[0]);\n      }\n      const ti=P.indexOf(tgt);\n      if(P[ti].hand.length&&P[ct].hand.length){\n        const ri=0|Math.random()*P[ti].hand.length;const taken=P[ti].hand.splice(ri,1)[0];\n        const gi=0|Math.random()*P[ct].hand.length;const given=P[ct].hand.splice(gi,1)[0];\n        P[ct].hand.push(taken);P[ti].hand.push(given);\n        if((ai._nyaBorrow||ai.role)==='寻宝者'&&isWinHand(P[ct].hand)){\n          P[ct].roleRevealed=true;\n          if(P[ti].role==='寻宝者'&&isWinHand(P[ti].hand)){\n            P[ti].roleRevealed=true;\n          }\n          return{...gs,players:P,gameOver:{winner:'寻宝者'}};\n        }\n        if(P[ti].role==='寻宝者'&&isWinHand(P[ti].hand)){\n          P[ti].roleRevealed=true;\n          return{...gs,players:P,gameOver:{winner:'寻宝者'}};\n        }\n      }\n    }\n  }\n  const win=checkWin(P);if(win)return{...gs,players:P,deck:D,discard:Disc,gameOver:win};\n  while(P[ct].hand.length>4){P[ct].hand.shift();}\n  \n  const hasValidTargets = getHunterTargets().length > 0;\n  const hasZoneCards = P[ct].hand.filter(c=>!c.isGod).length > 0;\n  if (aiEffRole === ROLE_HUNTER && huntContinue && hasZoneCards && hasValidTargets) {\n    return{...gs,players:P,deck:D,discard:Disc,phase:'AI_TURN',currentTurn:ct,huntAbandoned:newAbandoned,skillUsed:false};\n  } else {\n    return startNextTurn({...gs,players:P,deck:D,discard:Disc,currentTurn:ct,huntAbandoned:newAbandoned,skillUsed:(useSkill||gs.skillUsed)});\n  }\n}\n\nfunction runGame(N, verbose=false){\n  const names=AI_NAMES.slice(0,N);\n  const deck=mkDeck(),roles=mkRoles(N);\n  const players=names.map((name,i)=>({id:i,name,role:roles[i],hp:10,san:10,hand:[],isDead:false,isResting:false,godEncounters:0,godZone:[],godName:null,godLevel:0}));\n  for(let r=0;r<4;r++)players.forEach(p=>p.hand.push(deck.shift()));\n  let gs={players,deck,discard:[],currentTurn:-1,phase:'AI_TURN',abilityData:{},gameOver:null,skillUsed:false,restUsed:false,huntAbandoned:[],globalOnlySwapOwner:null,_turnKey:0,turn:0};\n  gs=startNextTurn(gs);\n  let turns=0,lastTurn=gs.turn;\n  while(!gs.gameOver&&turns<2000){\n    const prevTurn=gs.turn;\n    gs=gs.phase==='AI_TURN'?aiStep(gs):startNextTurn({...gs,currentTurn:gs.currentTurn});\n    if(gs.turn>prevTurn)turns=gs.turn;\n    const w=checkWin(gs.players);if(w&&!gs.gameOver)gs={...gs,gameOver:w};\n  }\n  const finalState={\n    alivePlayers:gs.players.filter(p=>!p.isDead).length,\n    livingPlayers:gs.players.filter(p=>!p.isDead).map(p=>({\n      name:p.name,role:p.role,hp:p.hp,san:p.san,handCount:p.hand.length\n    })),\n    roles:gs.players.map(p=>p.role),\n    deckCount:gs.deck.length,\n    discardCount:gs.discard.length\n  };\n  return{winner:gs.gameOver?.winner||'TIMEOUT',roles:gs.players.map(p=>p.role),turns,finalState};\n}\n\nconst GAMES=500;\nconst PLAYER_COUNT=5;\n\nconsole.log(`开始模拟 ${GAMES} 局 ${PLAYER_COUNT} 人游戏...`);\nconsole.time('模拟耗时');\n\nlet counts={\n  '寻宝者':0,\n  '追猎者':0,\n  '邪祀者':0,\n  'LOSE_ALL':0,\n  'TIMEOUT':0\n};\nlet roleDist={\n  '寻宝者':0,\n  '追猎者':0,\n  '邪祀者':0\n};\nlet totalTurns=0;\nlet turnsByWinner={};\nlet timeoutCases=[];\n\nfor(let i=0;i<GAMES;i++){\n  const result=runGame(PLAYER_COUNT);\n  counts[result.winner]=(counts[result.winner]||0)+1;\n  totalTurns+=result.turns;\n  turnsByWinner[result.winner]=(turnsByWinner[result.winner]||0)+result.turns;\n  result.roles.forEach(r=>roleDist[r]=(roleDist[r]||0)+1);\n  if(result.winner==='TIMEOUT'){\n    timeoutCases.push({index:i,finalState:result.finalState,turns:result.turns});\n  }\n  if((i+1)%10===0)console.log(`已完成 ${i+1}/${GAMES} 局...`);\n}\n\nconsole.timeEnd('模拟耗时');\nconsole.log('═══════════════════════════════════════════════════════════');\nconsole.log(`模拟结果 (${GAMES} 局 ${PLAYER_COUNT} 人游戏)`);\nconsole.log('═══════════════════════════════════════════════════════════');\nconsole.log(`寻宝者胜利: ${counts['寻宝者']} 局 (${(counts['寻宝者']/GAMES*100).toFixed(1)}%)`);\nconsole.log(`追猎者胜利: ${counts['追猎者']} 局 (${(counts['追猎者']/GAMES*100).toFixed(1)}%)`);\nconsole.log(`邪祀者胜利: ${counts['邪祀者']} 局 (${(counts['邪祀者']/GAMES*100).toFixed(1)}%)`);\nconsole.log(`全员失败: ${counts['LOSE_ALL']} 局 (${(counts['LOSE_ALL']/GAMES*100).toFixed(1)}%)`);\nconsole.log(`超时: ${counts['TIMEOUT']} 局 (${(counts['TIMEOUT']/GAMES*100).toFixed(1)}%)`);\nconsole.log('───────────────────────────────────────────────────────────────');\nconsole.log(`平均局数: ${(totalTurns/GAMES).toFixed(1)} 回合`);\nconsole.log('各阵营胜利时平均回合数:');\nObject.keys(turnsByWinner).forEach(w=>{\n  const avg=(turnsByWinner[w]/counts[w]).toFixed(1);\n  console.log(`  ${w}: ${avg} 回合`);\n});\nif(timeoutCases.length>0){\n  console.log('───────────────────────────────────────────────────────────────');\n  console.log(`超时局数: ${timeoutCases.length}`);\n  console.log('超时局详细状态:');\n  timeoutCases.slice(0,5).forEach((tc,idx)=>{\n    console.log(`  超时局 ${tc.index+1} (${tc.turns}回合):`);\n    console.log(`    存活玩家: ${tc.finalState.alivePlayers}`);\n    tc.finalState.livingPlayers.forEach(p=>{\n      console.log(`      ${p.name}(${p.role}): HP=${p.hp}, SAN=${p.san}, 手牌=${p.handCount}`);\n    });\n  });\n  if(timeoutCases.length>5)console.log(`  ...还有 ${timeoutCases.length-5} 局超时`);\n}\nconsole.log('═══════════════════════════════════════════════════════════');\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\zhuzi\\Documents\\ToE\\ToE_client_main\\sim_scripts\\simulate_trae.js","messages":[{"ruleId":"no-unused-vars","severity":2,"message":"'isMP' is defined but never used.","line":235,"column":28,"nodeType":"Identifier","messageId":"unusedVar","endLine":235,"endColumn":32,"suggestions":[{"messageId":"removeVar","data":{"varName":"isMP"},"fix":{"range":[15532,15538],"text":""},"desc":"Remove unused variable 'isMP'."}]},{"ruleId":"no-unused-vars","severity":2,"message":"'aiChooseRevealCard' is defined but never used. Allowed unused vars must match /^[A-Z_]/u.","line":302,"column":10,"nodeType":"Identifier","messageId":"unusedVar","endLine":302,"endColumn":28,"suggestions":[{"messageId":"removeVar","data":{"varName":"aiChooseRevealCard"},"fix":{"range":[17503,18012],"text":""},"desc":"Remove unused variable 'aiChooseRevealCard'."}]},{"ruleId":"no-unused-vars","severity":2,"message":"'living' is assigned a value but never used. Allowed unused vars must match /^[A-Z_]/u.","line":333,"column":9,"nodeType":"Identifier","messageId":"unusedVar","endLine":333,"endColumn":15,"suggestions":[{"messageId":"removeVar","data":{"varName":"living"},"fix":{"range":[18357,18397],"text":""},"desc":"Remove unused variable 'living'."}]}],"suppressedMessages":[],"errorCount":3,"fatalErrorCount":0,"warningCount":0,"fixableErrorCount":0,"fixableWarningCount":0,"source":"// 模拟脚本：基于App.jsx的游戏逻辑，用于模拟2-8人局对战并统计胜率（寻宝者掷骰子规避负面效果版）\n// 修正内容：\n// 1. 身份分配：使用limit=floor(N/2)的逻辑，与App.jsx一致\n// 2. 死亡玩家SAN检测：只检测存活者\n// 3. 超时处理：超时计TIMEOUT\n// 4. 规避触发时机：仅在摸牌时触发\n// 5. 规避概率：100%尝试×50%成功\n// 6. 玩家数：默认5人\n\nconst shuffle = (a) => {\n  const b = [...a];\n  for (let i = b.length - 1; i > 0; i--) {\n    const j = 0 | (Math.random() * (i + 1));\n    [b[i], b[j]] = [b[j], b[i]];\n  }\n  return b;\n};\n\nconst clamp = (v, lo = 0, hi = 10) => Math.max(lo, Math.min(hi, v));\n\nconst copyPlayers = (ps) => ps.map(p => ({ ...p, hand: [...p.hand], godZone: [...(p.godZone || [])] }));\n\nconst LETTERS = ['A', 'B', 'C', 'D'];\nconst NUMS = [1, 2, 3, 4];\n\nconst CS = {\n  A: { bg: '#100d1a', border: '#3a2a6a', borderBright: '#6050a0', text: '#b0a0e8', glow: '#3a2a6a' },\n  B: { bg: '#0a120a', border: '#1e4a1e', borderBright: '#3a7a3a', text: '#80d080', glow: '#1e4a1e' },\n  C: { bg: '#18120a', border: '#5a3a10', borderBright: '#8a6020', text: '#d4a840', glow: '#5a3a10' },\n  D: { bg: '#160a0a', border: '#6a1818', borderBright: '#a02828', text: '#e07070', glow: '#6a1818' },\n};\n\nconst ZONE_CARDS = {\n  A1: { pos: { name: '营地篝火', desc: '你回复2HP，相邻存活角色各失去2HP', type: 'selfHealAdjDamageHP', val: 2 }, negS: { name: '坠落', desc: '你失去3HP，随机弃1张牌（强制触发）', type: 'selfDamageDiscardHP', val: 3, forced: true }, negA: { name: '毒气喷涌', desc: '你与相邻存活角色失去1HP', type: 'adjDamageHP', val: 1 } },\n  A2: { pos: { name: '古代秘药', desc: '你回复1HP', type: 'selfHealHP', val: 1 }, negS: { name: '遭遇塌方', desc: '你失去3HP并翻面（切换休息状态）', type: 'selfDamageRestHP', val: 3 }, negA: { name: '地刺陷阱', desc: '你与相邻存活角色失去2HP', type: 'adjDamageHP', val: 2 } },\n  A3: { pos: { name: '吃下荧光苔藓', desc: 'HP回满，手牌全局公开，盲抽变挑选', type: 'selfRevealHandHP', val: 10 }, negS: { name: '理智动摇', desc: '你失去3SAN', type: 'selfDamageSAN', val: 3 }, negA: { name: '邪恶低语', desc: '你与相邻存活角色失去1SAN', type: 'adjDamageSAN', val: 1 } },\n  A4: { pos: { name: '绮丽诗篇', desc: '直到下回合，所有人技能变为\"掉包\"', type: 'globalOnlySwap', val: 0 }, negS: { name: '惊惧幻象', desc: '你失去3SAN', type: 'selfDamageSAN', val: 3 }, negA: { name: '灵魂尖啸', desc: '全体存活角色失去1SAN', type: 'allDamageSAN', val: 1 } },\n  B1: { pos: { name: '理智护符', desc: '你回复1SAN', type: 'selfHealSAN', val: 1 }, negS: { name: '忏悔独白', desc: '若信仰邪神则弃信受罚，否则失去1SAN', type: 'selfRenounceGod', val: 1 }, negA: { name: '绝望回声', desc: '你与相邻存活角色失去2SAN', type: 'adjDamageSAN', val: 2 } },\n  B2: { pos: { name: '强心剂', desc: '你回复2HP', type: 'selfHealHP', val: 2 }, negS: { name: '极度虚弱', desc: '你失去2SAN并翻面（切换休息状态）', type: 'selfDamageRestSAN', val: 2 }, negA: { name: '地动山摇', desc: '全体存活角色各随机弃1张牌（强制触发）', type: 'allDiscard', val: 1, forced: true } },\n  B3: { pos: { name: '互相包扎', desc: '你与相邻存活角色各回复3HP', type: 'adjHealHP', val: 3 }, negS: { name: '黑暗侵蚀', desc: '你失去2HP与1SAN', type: 'selfDamageHPSAN', hpVal: 2, sanVal: 1 }, negA: { name: '沉睡魔咒', desc: '你与相邻角色翻面（切换休息状态）', type: 'adjRest', val: 0 } },\n  B4: { pos: { name: '宁神香薰', desc: '你回复1SAN', type: 'selfHealSAN', val: 1 }, negS: { name: '落石砸击', desc: '你失去4HP', type: 'selfDamageHP', val: 4 }, negA: { name: '群体狂乱', desc: '全体存活角色失去1SAN', type: 'allDamageSAN', val: 1 } },\n  C1: { pos: { name: '军用口粮', desc: '你回复1HP与1SAN', type: 'selfHealBoth21', val: 0 }, negS: { name: '行囊破裂', desc: '你失去2HP与2SAN', type: 'selfDamageHPSAN', hpVal: 2, sanVal: 2 }, negA: { name: '毁灭风暴', desc: '全体存活角色失去3HP', type: 'allDamageHP', val: 3 } },\n  C2: { pos: { name: '急救药包', desc: '你回复3HP', type: 'selfHealHP', val: 3 }, negS: { name: '毒液飞溅', desc: '你失去3HP与1SAN', type: 'selfDamageHPSAN', hpVal: 3, sanVal: 1 }, negA: { name: '混乱气流', desc: '你与相邻角色各失去2HP', type: 'adjDamageHP', val: 2 } },\n  C3: { pos: { name: '均衡灵药', desc: '你回复1HP与1SAN', type: 'selfHealBoth', val: 1 }, negS: { name: '惊慌失措', desc: '你失去2SAN，随机弃1张牌（强制触发）', type: 'selfDamageDiscardSAN', val: 2, forced: true }, negA: { name: '瘟疫蔓延', desc: '你与相邻存活角色失去1HP和1SAN', type: 'adjDamageBoth', val: 1 } },\n  C4: { pos: { name: '强征献礼', desc: '选择一名角色，与其交换全部手牌', type: 'swapAllHands', val: 0 }, negS: { name: '恶毒诅咒', desc: '你失去2HP与2SAN', type: 'selfDamageHPSAN', hpVal: 2, sanVal: 2 }, negA: { name: '末日预兆', desc: '全体存活角色失去1HP和1SAN', type: 'allDamageBoth', val: 1 } },\n  D1: { pos: { name: '饮下清醒之泉', desc: '你回复3SAN，手牌全局公开，盲抽变挑选', type: 'selfRevealHandSAN', val: 3 }, negS: { name: '致命尖刺', desc: '你失去5HP', type: 'selfDamageHP', val: 5 }, negA: { name: '狂风席卷', desc: '全体存活角色失去1HP', type: 'allDamageHP', val: 1 } },\n  D2: { pos: { name: '净化仪式', desc: '你回复2SAN', type: 'selfHealSAN', val: 2 }, negS: { name: '邪神低语', desc: '你失去3SAN', type: 'selfDamageSAN', val: 3 }, negA: { name: '血肉畸变', desc: '你失去2HP与2SAN', type: 'selfDamageHPSAN', hpVal: 2, sanVal: 2 } },\n  D3: { pos: { name: '献祭治愈', desc: '你失去1SAN，全体回复1HP', type: 'sacHealHP', val: 1 }, negS: { name: '遗忘咒语', desc: '你失去2HP与1SAN', type: 'selfDamageHPSAN', hpVal: 2, sanVal: 1 }, negA: { name: '意志崩散', desc: '你失去3SAN', type: 'selfDamageSAN', val: 3 } },\n  D4: { pos: { name: '禁忌狂化', desc: '你失去1SAN，直到回合结束，你造成的伤害+1', type: 'selfBerserk', val: 1 }, negS: { name: '陷阱触发', desc: '你失去3HP，随机弃1张牌（强制触发）', type: 'selfDamageDiscardHP', val: 3, forced: true }, negA: { name: '理智崩坏', desc: '你失去3SAN', type: 'selfDamageSAN', val: 3 } },\n};\n\nconst ZONE_VARIANTS = ['pos', 'negS', 'negA'];\n\nconst GOD_DEFS = {\n  NYA: {\n    godKey: 'NYA', name: '伏行之混沌', subtitle: '奈亚拉托提普之化身', power: '千人千貌',\n    col: '#b03030', bgCol: '#200808',\n    levels: [\n      { handPenalty: 2, desc: '借用已死角色身份，本回合技能与胜利条件均变为该身份（手牌上限-2）' },\n      { handPenalty: 1, desc: '借用已死角色身份，本回合技能与胜利条件均变为该身份（手牌上限-1）' },\n      { handPenalty: 0, desc: '借用已死角色身份，本回合技能与胜利条件均变为该身份' },\n    ],\n  },\n  CTH: {\n    godKey: 'CTH', name: '拉莱耶之主', subtitle: '克苏鲁之化身', power: '梦访拉莱耶',\n    col: '#2060c0', bgCol: '#080820',\n    levels: [\n      { extraDraws: 1, desc: '在角色翻面状态下结束或跳过回合时，立即摸1张牌' },\n      { extraDraws: 2, desc: '在角色翻面状态下结束或跳过回合时，立即摸2张牌' },\n      { extraDraws: 3, desc: '在角色翻面状态下结束或跳过回合时，立即摸3张牌' },\n    ],\n  },\n};\n\nfunction buildDeck() {\n  const zoneCards = Object.entries(ZONE_CARDS).map(([key, variants]) => {\n    const letter = key[0];\n    const number = parseInt(key[1], 10);\n    return ZONE_VARIANTS.map(v => ({\n      key, variant: v,\n      name: variants[v].name, desc: variants[v].desc, letter, number, col: CS[letter],\n      type: variants[v].type, effectVal: variants[v].val,\n      forced: variants[v].forced,\n      hpVal: variants[v].hpVal, sanVal: variants[v].sanVal,\n    }));\n  }).flat();\n  const godCards = Object.values(GOD_DEFS).map(def => ({\n    isGod: true, godKey: def.godKey, name: def.name, subtitle: def.subtitle, power: def.power,\n    col: def.col, bgCol: def.bgCol, levels: def.levels,\n  }));\n  return shuffle([...zoneCards, ...godCards]);\n}\n\nfunction mkRoles(N = 5) {\n  // 拦截非法的游戏人数\n  if (N < 2) throw new Error('游戏人数不能少于2人');\n  \n  // 双人局：从三个基础身份中随机抽取两个不同的身份对战\n  if (N === 2) {\n    const baseRoles = ['寻宝者', '追猎者', '邪祀者'];\n    return shuffle(baseRoles).slice(0, 2);\n  }\n  \n  // 3人及以上：保证各身份至少1名\n  const roles = ['寻宝者', '追猎者', '邪祀者'];\n  const counts = { '寻宝者': 1, '追猎者': 1, '邪祀者': 1 };\n  \n  // 非寻宝者阵营的数量上限：向下取整的半数\n  const limit = Math.floor(N / 2);\n  \n  for (let i = 3; i < N; i++) {\n    const available = ['寻宝者']; // 寻宝者没有数量上限\n    if (counts['追猎者'] < limit) available.push('追猎者');\n    if (counts['邪祀者'] < limit) available.push('邪祀者');\n    \n    // 从允许的身份池中随机抽取一个\n    const pick = available[Math.floor(Math.random() * available.length)];\n    roles.push(pick);\n    counts[pick]++;\n  }\n  \n  return shuffle(roles);\n}\n\nconst isWinHand = (h) => {\n  const ls = new Set(h.map(c => c.letter));\n  const ns = new Set(h.map(c => c.number));\n  return LETTERS.every(l => ls.has(l)) && NUMS.every(n => ns.has(n));\n};\n\nfunction getPrevLivingIndex(players, ci) {\n  for (let step = 1; step < players.length; step++) {\n    const idx = (ci - step + players.length) % players.length;\n    if (idx !== ci && !players[idx].isDead) return idx;\n  }\n  return null;\n}\n\nfunction getNextLivingIndex(players, ci) {\n  for (let step = 1; step < players.length; step++) {\n    const idx = (ci + step) % players.length;\n    if (idx !== ci && !players[idx].isDead) return idx;\n  }\n  return null;\n}\n\nfunction applyFx(card, ci, ti, P, D, Disc) {\n  let msgs = [];\n  let statePatch = null;\n  const actor = P[ci];\n  const others = P.map((_, i) => i).filter(i => i !== ci && !P[i].isDead);\n  const adjacent = [getPrevLivingIndex(P, ci), getNextLivingIndex(P, ci)].filter(i => i !== null);\n  const allLiving = P.map((_, i) => i).filter(i => !P[i].isDead);\n  const dmgBonus = actor.damageBonus || 0;\n\n  const healHP = (i, v) => { P[i].hp = clamp(P[i].hp + v, 0, 10); };\n  const healSAN = (i, v) => { P[i].san = clamp(P[i].san + v, 0, 10); };\n  const dealHP = (i, v) => { P[i].hp = clamp(P[i].hp - (v + dmgBonus), 0, 10); };\n  const dealSAN = (i, v) => { P[i].san = clamp(P[i].san - (v + dmgBonus), 0, 10); };\n\n  switch (card.type) {\n    case 'selfHealHP': healHP(ci, card.effectVal); msgs.push(`${actor.name} 回复了 ${card.effectVal} HP`); break;\n    case 'selfHealSAN': healSAN(ci, card.effectVal); msgs.push(`${actor.name} 回复了 ${card.effectVal} SAN`); break;\n    case 'selfHealBoth': healHP(ci, card.effectVal); healSAN(ci, card.effectVal); msgs.push(`${actor.name} 回复了 ${card.effectVal} HP 和 ${card.effectVal} SAN`); break;\n    case 'selfHealBoth21': healHP(ci, 2); healSAN(ci, 1); msgs.push(`${actor.name} 回复了 2 HP 和 1 SAN`); break;\n    case 'selfDamageHP': dealHP(ci, card.effectVal); msgs.push(`${actor.name} 失去 ${card.effectVal + dmgBonus} HP`); break;\n    case 'selfDamageSAN': dealSAN(ci, card.effectVal); msgs.push(`${actor.name} 失去 ${card.effectVal + dmgBonus} SAN`); break;\n    case 'selfDamageHPSAN': dealHP(ci, card.hpVal); dealSAN(ci, card.sanVal); msgs.push(`${actor.name} 失去 ${card.hpVal + dmgBonus} HP 和 ${card.sanVal + dmgBonus} SAN`); break;\n    case 'selfDamageRestHP': dealHP(ci, card.effectVal); P[ci].isResting = !P[ci].isResting; msgs.push(`${actor.name} 失去 ${card.effectVal + dmgBonus} HP 并 ${P[ci].isResting ? '翻面' : '翻回正面'}`); break;\n    case 'selfDamageRestSAN': dealSAN(ci, card.effectVal); P[ci].isResting = !P[ci].isResting; msgs.push(`${actor.name} 失去 ${card.effectVal + dmgBonus} SAN 并 ${P[ci].isResting ? '翻面' : '翻回正面'}`); break;\n    case 'selfDamageDiscardHP': dealHP(ci, card.effectVal); if (P[ci].hand.length) { const ri = 0 | (Math.random() * P[ci].hand.length); Disc.push(P[ci].hand.splice(ri, 1)[0]); msgs.push(`${actor.name} 失去 ${card.effectVal + dmgBonus} HP，弃置一张牌`); } else { msgs.push(`${actor.name} 失去 ${card.effectVal + dmgBonus} HP`); } break;\n    case 'selfDamageDiscardSAN': dealSAN(ci, card.effectVal); if (P[ci].hand.length) { const ri = 0 | (Math.random() * P[ci].hand.length); Disc.push(P[ci].hand.splice(ri, 1)[0]); msgs.push(`${actor.name} 失去 ${card.effectVal + dmgBonus} SAN，弃置一张牌`); } else { msgs.push(`${actor.name} 失去 ${card.effectVal + dmgBonus} SAN`); } break;\n    case 'selfHealAdjDamageHP': healHP(ci, card.effectVal); adjacent.filter(i => i !== ci).forEach(i => dealHP(i, card.effectVal)); msgs.push(`${actor.name} 回复了 ${card.effectVal} HP，相邻角色各失去 ${card.effectVal + dmgBonus} HP`); break;\n    case 'adjHealHP': adjacent.forEach(i => healHP(i, card.effectVal)); msgs.push(`${actor.name} 与相邻角色各回复 ${card.effectVal} HP`); break;\n    case 'adjDamageHP': adjacent.forEach(i => dealHP(i, card.effectVal)); msgs.push(`${actor.name} 与相邻角色各失去 ${card.effectVal + dmgBonus} HP`); break;\n    case 'adjDamageSAN': adjacent.forEach(i => dealSAN(i, card.effectVal)); msgs.push(`${actor.name} 与相邻角色各失去 ${card.effectVal + dmgBonus} SAN`); break;\n    case 'adjDamageBoth': adjacent.forEach(i => { dealHP(i, card.effectVal); dealSAN(i, card.effectVal); }); msgs.push(`${actor.name} 与相邻角色各失去 ${card.effectVal + dmgBonus} HP 和 ${card.effectVal + dmgBonus} SAN`); break;\n    case 'allDamageHP': allLiving.forEach(i => dealHP(i, card.effectVal)); msgs.push(`全体存活角色失去 ${card.effectVal + dmgBonus} HP`); break;\n    case 'allDamageSAN': allLiving.forEach(i => dealSAN(i, card.effectVal)); msgs.push(`全体存活角色失去 ${card.effectVal + dmgBonus} SAN`); break;\n    case 'allDamageBoth': allLiving.forEach(i => { dealHP(i, card.effectVal); dealSAN(i, card.effectVal); }); msgs.push(`全体存活角色失去 ${card.effectVal + dmgBonus} HP 和 ${card.effectVal + dmgBonus} SAN`); break;\n    case 'allDiscard': allLiving.forEach(i => { if (P[i].hand.length) { const ri = 0 | (Math.random() * P[i].hand.length); Disc.push(P[i].hand.splice(ri, 1)[0]); } }); msgs.push('全体存活角色各弃置一张牌'); break;\n    case 'adjRest': adjacent.forEach(i => { P[i].isResting = !P[i].isResting; }); msgs.push(`${actor.name} 与相邻角色 ${P[adjacent[0]]?.isResting ? '翻面' : '翻回正面'}`); break;\n    case 'selfRevealHandHP': healHP(ci, card.effectVal); P[ci].handRevealed = true; msgs.push(`${actor.name} 手牌公开，回复 ${card.effectVal} HP`); break;\n    case 'selfRevealHandSAN': healSAN(ci, card.effectVal); P[ci].handRevealed = true; msgs.push(`${actor.name} 手牌公开，回复 ${card.effectVal} SAN`); break;\n    case 'globalOnlySwap': statePatch = { globalOnlySwapOwner: ci }; msgs.push(`直到 ${actor.name} 的下回合开始前，所有角色技能都视为\"掉包\"`); break;\n    case 'sacHealHP': dealSAN(ci, 1); allLiving.forEach(i => healHP(i, card.effectVal)); msgs.push(`${actor.name} 失去 1 SAN，随后全体回复 ${card.effectVal} HP`); break;\n    case 'sacHealSelfSAN': dealHP(ci, 3); healSAN(ci, card.effectVal); msgs.push(`${actor.name} 失去 3 HP，回复 ${card.effectVal} SAN`); break;\n    case 'swapAllHands': {\n      // Swap entire hand with the target (ti); if no ti provided, pick the living player with most cards\n      const swapTarget = ti != null ? ti : others.reduce((best, i) => P[i].hand.length > P[best].hand.length ? i : best, others[0] ?? ci);\n      if (swapTarget != null && swapTarget !== ci && P[swapTarget] && !P[swapTarget].isDead) {\n        const myHand = [...P[ci].hand];\n        P[ci].hand = [...P[swapTarget].hand];\n        P[swapTarget].hand = myHand;\n        msgs.push(`${actor.name} 与 ${P[swapTarget].name} 交换了全部手牌（${P[ci].hand.length} 张 ↔ ${P[swapTarget].hand.length} 张）`);\n        \n        // 检查双方是否都是寻宝者且都满足胜利条件（双寻宝者掉包共赢规则）\n        const isBothTreasureHunters = P[ci].role === '寻宝者' && P[swapTarget].role === '寻宝者';\n        const bothHaveWinHand = isWinHand(P[ci].hand) && isWinHand(P[swapTarget].hand);\n        if (isBothTreasureHunters && bothHaveWinHand) {\n          msgs.push(`${actor.name} 与 ${P[swapTarget].name} 互换后双方均集齐编号，两位寻宝者共同获胜！`);\n          statePatch = { doubleTreasureHunterWin: true, winnerIdx1: ci, winnerIdx2: swapTarget };\n        } else if (P[ci].role === '寻宝者' && isWinHand(P[ci].hand)) {\n          // 检查当前玩家是否是寻宝者且满足胜利条件\n          msgs.push(`${actor.name} 交换手牌后集齐编号，寻宝者获胜！`);\n          statePatch = { treasureHunterWin: true, winnerIdx: ci };\n        } else if (P[swapTarget].role === '寻宝者' && isWinHand(P[swapTarget].hand)) {\n          // 检查目标玩家是否是寻宝者且满足胜利条件\n          msgs.push(`${P[swapTarget].name} 交换手牌后集齐编号，寻宝者获胜！`);\n          statePatch = { treasureHunterWin: true, winnerIdx: swapTarget };\n        }\n      } else {\n        msgs.push(`${actor.name} 无法找到交换目标`);\n      }\n      break;\n    }\n    case 'selfBerserk': dealSAN(ci, 1); P[ci].damageBonus = (P[ci].damageBonus || 0) + 1; msgs.push(`${actor.name} 失去 1 SAN，本回合造成的伤害+1`); break;\n    case 'selfRenounceGod':\n      if (P[ci].godName) {\n        P[ci].san = clamp(P[ci].san - card.effectVal);\n        Disc.push(...P[ci].godZone);\n        P[ci].godZone = [];\n        P[ci].godName = null;\n        P[ci].godLevel = 0;\n        msgs.push(`${actor.name} 弃信邪神并受到惩罚，失去 ${card.effectVal} SAN`);\n      } else {\n        P[ci].san = clamp(P[ci].san - card.effectVal);\n        msgs.push(`${actor.name} 失去 ${card.effectVal} SAN`);\n      }\n      break;\n  }\n  return { P, D, Disc, msgs: msgs, statePatch };\n}\n\nfunction checkWin(players, isMP) {\n  const living = players.filter(p => !p.isDead);\n  \n  // 1. SAN归零：有邪祀者则邪祀者获胜；无邪祀者则全员失败（邪神复活但无人受益）\n  for (const p of living) {\n    if (p.san <= 0) {\n      const hasCultists = players.some(q => q.role === '邪祀者' && !q.isDead);\n      if (hasCultists) {\n        const ws = players.filter(q => q.role === '邪祀者' && !q.isDead).map(q => q.name).join('、');\n        return { winner: '邪祀者', reason: `${p.name} 的理智归零，邪神苏醒！邪祀者（${ws}）获胜！` };\n      } else {\n        return { winner: 'LOSE_ALL', reason: `${p.name} 的理智归零，邪神复活，无人幸存！全员失败！` };\n      }\n    }\n  }\n  \n  // 2. 追猎者胜利：所有非追猎者死亡\n  const livingNonHunters = living.filter(p => p.role !== '追猎者');\n  if (livingNonHunters.length === 0) {\n    const ws = players.filter(q => q.role === '追猎者' && !q.isDead).map(q => q.name).join('、');\n    return { winner: '追猎者', reason: `所有非追猎者已被肃清，追猎者（${ws}）获胜！` };\n  }\n  \n  // 3. 无人存活：全员失败\n  if (living.length === 0) {\n    return { winner: 'LOSE_ALL', reason: '所有角色均已死亡，全员失败！' };\n  }\n  \n  return null;\n}\n\nfunction initGame(N = 5) {\n  const D = buildDeck();\n  const roles = mkRoles(N);\n  const playerNames = N === 1 ? ['你'] : ['你', '艾伦', '贝拉', '卡洛斯', '黛安娜', '伊莎贝拉', '弗兰克', '格蕾丝'].slice(0, N);\n  const players = playerNames.map((name, i) => ({\n    id: i, name, role: roles[i], roleRevealed: false, hp: 8, san: 8, hand: [], godZone: [],\n    godName: null, godLevel: 0, godEncounters: 0, isDead: false, isResting: false,\n    handRevealed: false, damageBonus: 0,\n  }));\n  // 发牌：每人4张\n  for (let i = 0; i < 4; i++) {\n    for (const p of players) {\n      if (D.length === 0) break;\n      p.hand.push(D.pop());\n    }\n  }\n  return {\n    players,\n    deck: D,\n    discard: [],\n    currentTurn: 0,\n    phase: 'ACTION',\n    log: [`游戏开始！玩家：${playerNames.join('、')}`],\n    skillUsed: false,\n    restUsed: false,\n    huntAbandoned: [],\n    godFromHandUsed: false,\n    godTriggeredThisTurn: false,\n    abilityData: {},\n    drawReveal: null,\n    selectedCard: null,\n    gameOver: null,\n    _isMP: false,\n  };\n}\n\nfunction aiChooseRevealCard(zoneH, hunterH) {\n  // 简单的AI选择逻辑：选择与猎人手牌匹配度最高的牌\n  const hunterLetters = new Set(hunterH.map(c => c.letter));\n  const hunterNumbers = new Set(hunterH.map(c => c.number));\n  \n  let bestCard = zoneH[0];\n  let bestScore = 0;\n  \n  for (const card of zoneH) {\n    let score = 0;\n    if (hunterLetters.has(card.letter)) score++;\n    if (hunterNumbers.has(card.number)) score++;\n    if (score > bestScore) {\n      bestScore = score;\n      bestCard = card;\n    }\n  }\n  \n  return bestCard;\n}\n\nfunction aiStep(gs) {\n  const { players: ps, currentTurn: ct } = gs;\n  let P = copyPlayers(ps);\n  let D = [...gs.deck];\n  let Disc = [...gs.discard];\n  const L = [...gs.log];\n  const ai = P[ct];\n  const aiRole = ai.role;\n  const aiEffRole = ai._nyaBorrow || aiRole;\n  const others = P.map((_, i) => i).filter(i => i !== ct && !P[i].isDead);\n  const living = P.filter(p => !p.isDead);\n  \n  // 1. 决定行动：技能 / 休息 / 结束\n  let action = 'end';\n  const skillRate = 0.5; // 基础技能使用率\n  if (Math.random() < skillRate) {\n    if (aiEffRole === '追猎者' && others.length > 0) {\n      action = 'skill';\n    } else if (aiEffRole === '邪祀者' && others.length > 0 && ai.hand.length > 0) {\n      action = 'skill';\n    } else if (aiEffRole === '寻宝者' && others.length > 0 && ai.hand.length > 0) {\n      action = 'skill';\n    }\n  } else if (ai.hp < 5 && !ai.isResting) {\n    action = 'rest';\n  }\n  \n  // 2. 执行行动\n  if (action === 'skill') {\n    if (aiEffRole === '追猎者') {\n      // 追猎者追捕：选择目标并造成伤害\n      const livingNonHunters = others.filter(i => P[i].role !== '追猎者');\n      if (livingNonHunters.length > 0) {\n        const tgt = livingNonHunters[0 | (Math.random() * livingNonHunters.length)];\n        const tgtHand = P[tgt].hand.filter(c => !c.isGod);\n        if (tgtHand.length > 0 && P[ct].hand.filter(c => !c.isGod).length > 0) {\n          // 目标亮出一张牌\n          const revealedCard = tgtHand[0 | (Math.random() * tgtHand.length)];\n          // 追猎者弃掉一张与目标亮出的牌匹配的区域牌\n          const matchingCardIndex = P[ct].hand.findIndex(c => !c.isGod && (c.letter === revealedCard.letter || c.number === revealedCard.number));\n          if (matchingCardIndex !== -1) {\n            const discardedCard = P[ct].hand.splice(matchingCardIndex, 1)[0];\n            Disc.push(discardedCard);\n            P[tgt].hp = clamp(P[tgt].hp - 2);\n            L.push(`${ai.name}（追猎者）对 ${P[tgt].name} 【追捕】，弃置 [${discardedCard.key}] 并造成 2 点伤害`);\n            if (P[tgt].hp <= 0) {\n              P[tgt].isDead = true;\n              L.push(`${P[tgt].name} 已死亡`);\n            }\n          } else {\n            L.push(`${ai.name}（追猎者）无法找到与目标匹配的牌，无法进行追捕`);\n          }\n        } else {\n          L.push(`${ai.name}（追猎者）或目标没有区域牌，无法进行追捕`);\n        }\n      } else {\n        L.push(`${ai.name}（追猎者）没有可追捕的目标`);\n      }\n    } else if (aiEffRole === '邪祀者') {\n      // 邪祀者蛊惑：选择目标并送牌\n      const tgt = others[0 | (Math.random() * others.length)];\n      const cardIdx = 0 | (Math.random() * ai.hand.length);\n      const card = ai.hand[cardIdx];\n      ai.hand.splice(cardIdx, 1);\n      P[tgt].hand.push(card);\n      L.push(`${ai.name}（邪祀者）对 ${P[tgt].name} 【蛊惑】，赠予 [${card.key}] ${card.name}`);\n      \n      // 处理邪神牌遭遇\n      if (card.isGod) {\n        P[tgt].godEncounters++;\n        const cost = P[tgt].godEncounters;\n        P[tgt].san = clamp(P[tgt].san - cost);\n        L.push(`${P[tgt].name} 遭遇邪神 ${card.name}（第${P[tgt].godEncounters}次），失去${cost}SAN`);\n        \n        // 检查是否信仰邪神\n        const willWorship = Math.random() < 0.45;\n        if (willWorship) {\n          P[tgt].godName = card.godKey;\n          P[tgt].godLevel = 1;\n          P[tgt].godZone.push(card);\n          L.push(`${P[tgt].name} 信仰了邪神 ${card.name}`);\n        } else {\n          Disc.push(card);\n          L.push(`${P[tgt].name} 拒绝了邪神的馈赠`);\n        }\n      } else if (card.type === 'negS' || card.type === 'negA') {\n        // 处理负面牌效果\n        const res = applyFx(card, tgt, null, P, D, Disc);\n        P = res.P;\n        D = res.D;\n        Disc = res.Disc;\n        if (res.msgs.length) L.push(...res.msgs);\n      }\n    } else if (aiEffRole === '寻宝者') {\n      // 寻宝者掉包：与目标交换一张牌\n      if (P[ct].hand.length === 0 || others.length === 0) {\n        L.push(`${ai.name} 或目标没有手牌，无法进行掉包`);\n      } else {\n        const tgt = others[0 | (Math.random() * others.length)];\n        if (P[tgt].hand.length === 0) {\n          L.push(`${ai.name} 或目标没有手牌，无法进行掉包`);\n        } else {\n          const myCardIndex = Math.floor(Math.random() * P[ct].hand.length);\n          const myCard = P[ct].hand[myCardIndex];\n          const theirCardIndex = Math.floor(Math.random() * P[tgt].hand.length);\n          const theirCard = P[tgt].hand[theirCardIndex];\n          \n          P[ct].hand[myCardIndex] = theirCard;\n          P[tgt].hand[theirCardIndex] = myCard;\n          L.push(`${ai.name} 与 ${P[tgt].name} 交换了一张牌：[${myCard.key}] ${myCard.name} ↔ [${theirCard.key}] ${theirCard.name}`);\n          \n          // 检查双方是否都是寻宝者且都满足胜利条件（双寻宝者掉包共赢规则）\n          const isBothTreasureHunters = P[ct].role === '寻宝者' && P[tgt].role === '寻宝者';\n          const bothHaveWinHand = isWinHand(P[ct].hand) && isWinHand(P[tgt].hand);\n          if (isBothTreasureHunters && bothHaveWinHand) {\n            L.push(`${ai.name} 与 ${P[tgt].name} 掉包后双方均集齐编号，两位寻宝者共同获胜！`);\n            return { ...gs, players: P, deck: D, discard: Disc, log: L, gameOver: { winner: '寻宝者', reason: `${ai.name} 与 ${P[tgt].name} 掉包后双方均集齐编号，两位寻宝者共同获胜！`, winnerIdx: ct, winnerIdx2: tgt } };\n          }\n        }\n      }\n    }\n  } else if (action === 'rest') {\n    // 休息：翻面并回复HP\n    P[ct].isResting = true;\n    const heal = Math.max(...Array.from({ length: 2 }, () => 1 + Math.floor(Math.random() * 6)));\n    P[ct].hp = clamp(P[ct].hp + heal, 0, 10);\n    L.push(`${ai.name} 选择【休息】，翻面并回复 ${heal} HP`);\n  } else {\n    L.push(`${ai.name} 结束回合`);\n  }\n  \n  // 3. 检查游戏结束\n  const win = checkWin(P, gs._isMP);\n  if (win) return { ...gs, players: P, deck: D, discard: Disc, log: L, gameOver: win };\n  \n  // 4. 检查寻宝者胜利\n  if (!P[ct].isDead && P[ct].role === '寻宝者' && isWinHand(P[ct].hand)) {\n    P[ct].roleRevealed = true;\n    return { ...gs, players: P, deck: D, discard: Disc, log: [...L, `${P[ct].name} 集齐了全部编号并获胜！`], gameOver: { winner: '寻宝者', reason: `${P[ct].name} 集齐了全部编号并获胜！`, winnerIdx: ct } };\n  }\n  \n  return { ...gs, players: P, deck: D, discard: Disc, log: L };\n}\n\nfunction aiDrawAndApply(ci, ps, deck, disc) {\n  let P = copyPlayers(ps);\n  let D = [...deck];\n  let Disc = [...disc];\n  let effectMsgs = [];\n  let statePatch = null;\n  let needGodChoice = false;\n  let drawnCard = null;\n  \n  const actor = P[ci];\n  \n  // 1. 摸牌\n  if (!actor.isResting) {\n    if (D.length === 0) {\n      D = shuffle(Disc);\n      Disc = [];\n      effectMsgs.push('牌库耗尽，洗牌弃牌堆');\n    }\n    if (D.length > 0) {\n      const card = D.pop();\n      drawnCard = card;\n      \n      // 寻宝者掷骰子规避负面效果\n      if (actor.role === '寻宝者' && (card.variant === 'negS' || card.variant === 'negA') && !card.forced) {\n        // 100%尝试规避，50%成功\n        if (Math.random() < 0.5) {\n          effectMsgs.push(`${actor.name}（寻宝者）掷骰子成功，规避了 [${card.key}] 的负面效果！`);\n          Disc.push(card);\n        } else {\n          effectMsgs.push(`${actor.name}（寻宝者）掷骰子失败，无法规避 [${card.key}] 的负面效果`);\n          P[ci].hand.push(card);\n          \n          // 处理负面牌效果\n          const res = applyFx(card, ci, null, P, D, Disc);\n          P = res.P;\n          D = res.D;\n          Disc = res.Disc;\n          if (res.msgs.length) effectMsgs.push(...res.msgs);\n          if (res.statePatch) statePatch = res.statePatch;\n        }\n      } else if (card.isGod) {\n        // 邪神牌：选择是否信仰\n        needGodChoice = true;\n      } else {\n        // 普通牌：直接加入手牌\n        P[ci].hand.push(card);\n        \n        // 处理正面牌效果\n        if (card.variant === 'pos') {\n          const res = applyFx(card, ci, null, P, D, Disc);\n          P = res.P;\n          D = res.D;\n          Disc = res.Disc;\n          if (res.msgs.length) effectMsgs.push(...res.msgs);\n          if (res.statePatch) statePatch = res.statePatch;\n        }\n      }\n      \n      // 手牌上限检查：最多4张\n      while (P[ci].hand.length > 4) {\n        Disc.push(P[ci].hand.shift());\n        effectMsgs.push(`${actor.name} 手牌超过上限，弃置一张牌`);\n      }\n    }\n  } else {\n    // 休息状态：翻回正面\n    P[ci].isResting = false;\n    effectMsgs.push(`${actor.name} 结束休息状态，翻回正面`);\n  }\n  \n  return { P, D, Disc, effectMsgs, statePatch, needGodChoice, drawnCard };\n}\n\nfunction startNextTurn(gs) {\n  const { players: ps, currentTurn: ct, _isMP } = gs;\n  let P = copyPlayers(ps);\n  let D = [...gs.deck];\n  let Disc = [...gs.discard];\n  const L = [...gs.log];\n  \n  // 1. 清除临时状态\n  P.forEach(p => { p.damageBonus = 0; p._nyaBorrow = null; p._nyaHandLimit = null; });\n  \n  // 2. 确定下一个回合的玩家\n  let next = ct;\n  do {\n    next = (next + 1) % P.length;\n  } while (P[next].isDead && next !== ct);\n  \n  // 3. 如果是玩家回合\n  if (next === 0) {\n    const res = aiDrawAndApply(0, P, D, Disc);\n    P = res.P;\n    D = res.D;\n    Disc = res.Disc;\n    if (res.effectMsgs.length) L.push(...res.effectMsgs);\n    \n    // 检查是否有寻宝者因交换手牌而获胜的情况\n    if (res.statePatch?.treasureHunterWin) {\n      const winner = P[res.statePatch.winnerIdx].name;\n      return { ...gs, players: P, deck: D, discard: Disc, log: [...L, ...res.effectMsgs], gameOver: { winner: '寻宝者', reason: `${winner} 交换手牌后集齐编号，寻宝者获胜！`, winnerIdx: res.statePatch.winnerIdx } };\n    }\n    \n    // 检查是否有双寻宝者掉包共赢的情况\n    if (res.statePatch?.doubleTreasureHunterWin) {\n      const winner1 = P[res.statePatch.winnerIdx1].name;\n      const winner2 = P[res.statePatch.winnerIdx2].name;\n      return { ...gs, players: P, deck: D, discard: Disc, log: [...L, ...res.effectMsgs], gameOver: { winner: '寻宝者', reason: `${winner1} 与 ${winner2} 互换后双方均集齐编号，两位寻宝者共同获胜！`, winnerIdx: res.statePatch.winnerIdx1, winnerIdx2: res.statePatch.winnerIdx2 } };\n    }\n    \n    const win = checkWin(P, gs._isMP);\n    if (win) return { ...gs, players: P, deck: D, discard: Disc, log: L, gameOver: win };\n    if (!P[0].isDead && P[0].role === '寻宝者' && isWinHand(P[0].hand)) {\n      P[0].roleRevealed = true;\n      return { ...gs, players: P, deck: D, discard: Disc, log: [...L, `${P[0].name} 集齐全部编号并获胜！`], gameOver: { winner: '寻宝者', reason: `${P[0].name} 集齐了全部编号并获胜！`, winnerIdx: 0 } };\n    }\n    return { ...gs, players: P, deck: D, discard: Disc, log: L, currentTurn: 0, phase: 'AI_TURN', drawReveal: null, selectedCard: null, abilityData: {}, huntAbandoned: [], _drawnCard: res.drawnCard ?? null, _turnKey: (gs._turnKey || 0) + 1, ...(res.statePatch || {}), globalOnlySwapOwner: (res.statePatch?.globalOnlySwapOwner ?? gs.globalOnlySwapOwner) };\n  } else {\n    // AI回合\n    const res = aiDrawAndApply(next, P, D, Disc);\n    P = res.P;\n    D = res.D;\n    Disc = res.Disc;\n    if (res.effectMsgs.length) L.push(...res.effectMsgs);\n    \n    // 检查是否有寻宝者因交换手牌而获胜的情况\n    if (res.statePatch?.treasureHunterWin) {\n      const winner = P[res.statePatch.winnerIdx].name;\n      return { ...gs, players: P, deck: D, discard: Disc, log: [...L, ...res.effectMsgs], gameOver: { winner: '寻宝者', reason: `${winner} 交换手牌后集齐编号，寻宝者获胜！`, winnerIdx: res.statePatch.winnerIdx }, ...(res.statePatch || {}), globalOnlySwapOwner: (res.statePatch?.globalOnlySwapOwner ?? gs.globalOnlySwapOwner) };\n    }\n    \n    // 检查是否有双寻宝者掉包共赢的情况\n    if (res.statePatch?.doubleTreasureHunterWin) {\n      const winner1 = P[res.statePatch.winnerIdx1].name;\n      const winner2 = P[res.statePatch.winnerIdx2].name;\n      return { ...gs, players: P, deck: D, discard: Disc, log: [...L, ...res.effectMsgs], gameOver: { winner: '寻宝者', reason: `${winner1} 与 ${winner2} 互换后双方均集齐编号，两位寻宝者共同获胜！`, winnerIdx: res.statePatch.winnerIdx1, winnerIdx2: res.statePatch.winnerIdx2 }, ...(res.statePatch || {}), globalOnlySwapOwner: (res.statePatch?.globalOnlySwapOwner ?? gs.globalOnlySwapOwner) };\n    }\n    \n    const win = checkWin(P, gs._isMP);\n    if (win) return { ...gs, players: P, deck: D, discard: Disc, log: L, gameOver: win, ...(res.statePatch || {}), globalOnlySwapOwner: (res.statePatch?.globalOnlySwapOwner ?? gs.globalOnlySwapOwner) };\n    if (!P[next].isDead && P[next].role === '寻宝者' && isWinHand(P[next].hand)) {\n      P[next].roleRevealed = true;\n      return { ...gs, players: P, deck: D, discard: Disc, log: [...L, `${P[next].name} 集齐了全部编号并获胜！`], gameOver: { winner: '寻宝者', reason: `${P[next].name} 集齐了全部编号并获胜！`, winnerIdx: next }, ...(res.statePatch || {}), globalOnlySwapOwner: (res.statePatch?.globalOnlySwapOwner ?? gs.globalOnlySwapOwner) };\n    }\n    \n    // 执行AI行动\n    const aiResult = aiStep({ ...gs, players: P, deck: D, discard: Disc, log: L, currentTurn: next });\n    return aiResult;\n  }\n}\n\nfunction simulateGame(N = 5, maxTurns = 100) {\n  let gs = initGame(N);\n  let turn = 0;\n  \n  while (!gs.gameOver && turn < maxTurns) {\n    gs = startNextTurn(gs);\n    turn++;\n  }\n  \n  if (!gs.gameOver) {\n    // 超时处理：计TIMEOUT\n    return 'TIMEOUT';\n  }\n  \n  return gs.gameOver.winner;\n}\n\nfunction runSimulations(N = 5, simulations = 1000) {\n  const results = { '寻宝者': 0, '追猎者': 0, '邪祀者': 0, 'LOSE_ALL': 0, 'TIMEOUT': 0 };\n  \n  console.log(`模拟 ${N} 人局...`);\n  \n  for (let i = 1; i <= simulations; i++) {\n    if (i % 100 === 0) {\n      console.log(`  ${N}人局: ${i}/${simulations} 局完成`);\n    }\n    const winner = simulateGame(N);\n    results[winner] = (results[winner] || 0) + 1;\n  }\n  \n  return results;\n}\n\n// 运行模拟\nfunction main() {\n  console.log('开始模拟2-8人局胜率...\\n');\n  \n  for (let N = 2; N <= 8; N++) {\n    const results = runSimulations(N, 1000);\n    \n    console.log(`\\n${N}人局胜率统计:`);\n    console.log(`  寻宝者: ${(results['寻宝者'] / 10).toFixed(2)}% (${results['寻宝者']}局)`);\n    console.log(`  追猎者: ${(results['追猎者'] / 10).toFixed(2)}% (${results['追猎者']}局)`);\n    console.log(`  邪祀者: ${(results['邪祀者'] / 10).toFixed(2)}% (${results['邪祀者']}局)`);\n    console.log(`  LOSE_ALL: ${(results['LOSE_ALL'] / 10).toFixed(2)}% (${results['LOSE_ALL']}局)`);\n    console.log(`  TIMEOUT: ${(results['TIMEOUT'] / 10).toFixed(2)}% (${results['TIMEOUT']}局)`);\n  }\n  \n  console.log('\\n模拟完成！');\n}\n\nmain();","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\zhuzi\\Doc