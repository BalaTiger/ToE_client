 )}\n          </React.Fragment>\n        );\n      })}\n    </div>\n  );\n}\n\nexport { KnifeEffect, GuillotineAnim };\n","usedDeprecatedRules":[]},{"filePath":"C:\\Users\\zhuzi\\Documents\\ToE\\ToE_client_main\\src\\components\\anim\\GenericAnimOverlay.jsx","messages":[{"ruleId":"react-hooks/purity","severity":2,"message":"Error: Cannot call impure function during render\n\n`Math.random` is an impure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\n  30 |         <div key={i} style={{\n  31 |           position: 'absolute',\n> 32 |           width: 10 + Math.random() * 20,\n     |                       ^^^^^^^^^^^^^ Cannot call impure function\n  33 |           height: 10 + Math.random() * 20,\n  34 |           background: '#8a6a40',\n  35 |           borderRadius: Math.random() * 5,","line":32,"column":23,"nodeType":null,"endLine":32,"endColumn":36},{"ruleId":"react-hooks/purity","severity":2,"message":"Error: Cannot call impure function during render\n\n`Math.random` is an impure function. Calling an impure function can produce unstable results that update unpredictably when the component happens to re-render. (https://react.dev/reference/rules/components-and-hooks-must-be-pure#components-and-hooks-must-be-idempotent).\n\n  31 |           position: 'absolute',\n  32 |           width: 10 + Math.random() * 20,\n> 33 |           height: 10 + Math.random() * 20,\n     |                        ^^^^^^^^^^^^^ Cannot call impure function\n  34 |           background: '#8a6a40',\n  35 |           borderRadius: Math.random() * 5,\n  36 |           left: Math.random() * 100 + '%',","line":33,"column":24,"nodeType":null,"endLine":33,"endColumn":37},{"ruleId":"react-hooks/purity","severity":2,"message":"Error: Cannot call impure function during render\n\n`Math.random` is an impur